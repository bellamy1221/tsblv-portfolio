---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/BrandMark.astro';
---

<BaseLayout title="Brand system preview — TSBLV" description="Скрытая страница проверки фирменного знака TSBLV." noindex={true}>
  <main class="brand-preview" id="main-content" tabindex="-1">
    <header class="site-container preview-header">
      <p class="section-label">Brand system</p>
      <h1>TSBLV Brand Mark</h1>
      <p>Размеры, композиции и контраст текстового фирменного знака.</p>
    </header>

    <section class="preview-section" aria-labelledby="marks-title">
      <div class="site-container">
        <h2 id="marks-title">Основной фон</h2>
        <div class="preview-grid">
          <div><span>Full / small</span><BrandMark variant="full" size="small" /></div>
          <div><span>Full / medium</span><BrandMark variant="full" size="medium" /></div>
          <div><span>Full / large</span><BrandMark variant="full" size="large" /></div>
          <div><span>Wordmark</span><BrandMark variant="wordmark" size="medium" /></div>
          <div><span>Symbol</span><BrandMark variant="symbol" size="medium" /></div>
          <div><span>Vertical</span><BrandMark variant="full" size="medium" orientation="vertical" /></div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .brand-preview { min-height: 100vh; padding-bottom: 6rem; }
  .preview-header { padding-block: 5rem; }
  .preview-header h1 { margin: 0; font-size: clamp(3rem, 8vw, 7rem); font-weight: 600; line-height: .95; letter-spacing: -.07em; }
  .preview-header > p:last-child { max-width: 35rem; color: var(--muted); }
  .preview-section h2 { margin-bottom: 2rem; font-size: clamp(2rem, 4vw, 4rem); }
  .preview-grid { display: grid; gap: 1px; border: 1px solid var(--line); background: var(--line); }
  .preview-grid > div { display: grid; min-height: 14rem; align-content: space-between; gap: 2rem; padding: clamp(1.25rem, 3vw, 2.5rem); background: var(--paper); }
  .preview-grid span { color: var(--muted); font-size: .6rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; }
  @media (min-width: 48rem) { .preview-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
