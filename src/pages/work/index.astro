---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/projects/ProjectCard.astro';
import { getAllProjects } from '../../lib/projects';

const projects = await getAllProjects();
const title = 'Работы — TSBLV';
const description = 'Избранные сайты, сервисы и визуальные системы TSBLV — от функциональных интерфейсов до имиджевых цифровых проектов.';
---

<BaseLayout title={title} description={description}>
  <Header />
  <main id="main-content" tabindex="-1">
    <section class="work-page section" aria-labelledby="work-page-title">
      <div class="container">
        <p class="section-label" data-reveal="fade">Портфолио</p>
        <h1 id="work-page-title" data-reveal="up">Работы</h1>
        <p class="lead" data-reveal="up" data-delay="80">Сайты, сервисы и визуальные системы — от спокойных функциональных интерфейсов до выразительных имиджевых проектов.</p>

        <ul class="project-list list-reset" data-stagger data-stagger-delay="70">
          {projects.map((project) => (
            <li><ProjectCard project={project} headingLevel="h2" /></li>
          ))}
        </ul>
      </div>
    </section>
    <Contact />
  </main>
  <Footer />
</BaseLayout>

<style>
  .work-page { border-top: 0; }
  .project-list { margin-top: var(--section-space-small); }
</style>
