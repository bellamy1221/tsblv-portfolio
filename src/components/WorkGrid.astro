---
import { getFeaturedProjects } from '../lib/projects';
import ProjectCard from './projects/ProjectCard.astro';

const projects = await getFeaturedProjects();
---

<section class="section work-section" id="work" aria-labelledby="work-title">
  <div class="container">
    <div class="section-header work-header">
      <div data-reveal="up">
        <p class="section-label">Selected work</p>
        <h2 id="work-title">Избранные проекты</h2>
      </div>
      <a class="link-arrow" href="/work/" data-reveal="fade" data-delay="120">Все работы</a>
    </div>
    <ul class="project-list project-list--featured list-reset" data-stagger data-stagger-delay="70">
      {projects.map((project, index) => (
        <li class:list={[{ 'is-featured': index === 0 && projects.length > 1 }]}>
          <ProjectCard project={project} featured={index === 0 && projects.length > 1} />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .work-section {
    position: relative;
  }

  .work-header {
    align-items: end;
  }

  .work-header .link-arrow {
    justify-self: start;
  }

  .project-list--featured {
    gap: clamp(2rem, 4vw, 3rem);
  }

  @media (min-width: 48rem) {
    .work-header .link-arrow {
      justify-self: end;
    }

    .project-list--featured > .is-featured {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 75rem) {
    .project-list--featured {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: clamp(2rem, 3vw, 2.5rem) clamp(1.5rem, 2.5vw, 2rem);
    }

    .project-list--featured > .is-featured {
      grid-column: span 2;
    }
  }
</style>
