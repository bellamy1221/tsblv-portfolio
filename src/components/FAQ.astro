---
import { faqItems } from '../data/home';
---

<section class="section faq" aria-labelledby="faq-title" data-pointer-light>
  <div class="faq-orbit" aria-hidden="true"><span>06</span><i></i><b></b></div>

  <div class="site-container content-grid faq-heading" data-motion="clip">
    <div>
      <p class="section-label">06 / Перед стартом</p>
      <h2 id="faq-title">Ответы,<br />которые дают уверенность</h2>
    </div>
    <p>Без скрытых условий и сложных формулировок. Откройте вопрос — ответ появится в том же спокойном ритме.</p>
  </div>

  <div class="site-container faq-list" data-sequence>
    {faqItems.map((item, index) => (
      <details data-motion="row" data-motion-delay={index * 45}>
        <summary>
          <span>0{index + 1}</span>
          <strong>{item.question}</strong>
          <i aria-hidden="true"><b></b></i>
        </summary>
        <div class="faq-answer"><p>{item.answer}</p></div>
      </details>
    ))}
  </div>
</section>

<style is:global>
  .faq {
    --pointer-x: 72%;
    --pointer-y: 28%;
    position: relative;
    isolation: isolate;
    overflow: clip;
    padding-block: clamp(9rem, 12vw, 13rem);
    background: transparent;
  }

  .faq-heading { position: relative; z-index: 2; display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(19rem, 0.6fr); align-items: end; gap: clamp(2rem, 6vw, 7rem); }
  .faq-heading > div,
  .faq-heading > p { min-width: 0; grid-column: auto; }
  .faq-heading > p { max-width: 28rem; margin: 0 0 0.4rem; color: var(--text-muted); font-size: 0.9rem; line-height: 1.65; }
  .faq-heading h2 { font-size: clamp(3rem, 6.4vw, 6.7rem); }

  .faq-orbit { position: absolute; z-index: -1; top: clamp(4rem, 7vw, 7rem); right: 4vw; width: clamp(12rem, 25vw, 25rem); aspect-ratio: 1; border-radius: 50%; opacity: 0.62; }
  .faq-orbit::before,
  .faq-orbit::after { position: absolute; inset: 12%; border: 1px solid color-mix(in srgb, var(--text) 12%, transparent); border-radius: 50%; content: ''; }
  .faq-orbit::after { inset: 27%; border-color: color-mix(in srgb, var(--yellow) 34%, transparent); animation: faq-orbit-turn 13s linear infinite reverse; }
  .faq-orbit > span { position: absolute; inset: 0; display: grid; place-items: center; color: color-mix(in srgb, var(--text) 8%, transparent); font-size: clamp(7rem, 18vw, 18rem); font-weight: 730; letter-spacing: -0.08em; }
  .faq-orbit > i,
  .faq-orbit > b { position: absolute; top: 50%; left: 50%; width: 74%; height: 1px; background: linear-gradient(90deg, transparent, var(--red), transparent); transform-origin: left; animation: faq-orbit-turn 10s linear infinite; }
  .faq-orbit > b { width: 58%; background: linear-gradient(90deg, transparent, var(--yellow), transparent); animation-duration: 16s; animation-direction: reverse; }

  .faq-list { position: relative; z-index: 2; display: grid; max-width: 74rem; gap: 0.7rem; margin-top: clamp(4rem, 7vw, 7rem); }
  .faq details { position: relative; overflow: hidden; border-radius: 999px; background: rgba(247, 245, 239, 0.055); box-shadow: 0 1.25rem 3rem rgba(0, 0, 0, 0.12); transition: background 420ms ease, border-radius 520ms var(--ease-out), transform 480ms var(--ease-out), box-shadow 480ms ease; }
  .faq details::before { position: absolute; inset: 0; background: radial-gradient(ellipse at 12% 50%, rgba(181, 31, 43, 0.16), transparent 36%), radial-gradient(ellipse at 88% 50%, rgba(228, 185, 31, 0.14), transparent 38%); content: ''; opacity: 0; transition: opacity 420ms ease; }
  .faq details:hover,
  .faq details:focus-within { transform: translateX(0.35rem); box-shadow: 0 1.6rem 3.8rem rgba(0, 0, 0, 0.18); }
  .faq details[open] { border-radius: 2rem; background: rgba(247, 245, 239, 0.09); }
  .faq details:hover::before,
  .faq details:focus-within::before,
  .faq details[open]::before { opacity: 1; }

  .faq summary { position: relative; z-index: 1; display: grid; min-height: clamp(5.2rem, 7vw, 6.5rem); grid-template-columns: 3.2rem minmax(0, 1fr) 3rem; align-items: center; gap: 1rem; padding: 0.75rem 1.2rem; color: var(--text); cursor: pointer; list-style: none; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary > span { display: grid; width: 2.4rem; aspect-ratio: 1; place-items: center; border-radius: 50%; background: rgba(247, 245, 239, 0.08); color: var(--text-muted); font-size: 0.56rem; transition: background 420ms ease, color 420ms ease, transform 520ms var(--ease-out); }
  .faq summary strong { min-width: 0; font-size: clamp(1.05rem, 1.85vw, 1.55rem); font-weight: 570; letter-spacing: -0.035em; overflow-wrap: anywhere; }
  .faq summary > i { position: relative; display: grid; width: 2.6rem; aspect-ratio: 1; place-items: center; border-radius: 50%; background: var(--text); color: var(--page); }
  .faq summary > i::before,
  .faq summary > i::after { position: absolute; width: 0.9rem; height: 1px; background: currentColor; content: ''; transition: transform 440ms var(--ease-out); }
  .faq summary > i::after { transform: rotate(90deg); }
  .faq summary > i b { position: absolute; inset: -0.35rem; border: 1px solid color-mix(in srgb, var(--yellow) 62%, transparent); border-radius: 50%; opacity: 0; scale: 0.72; transition: opacity 420ms ease, scale 520ms var(--ease-out); }
  .faq details:hover summary > span,
  .faq details[open] summary > span { background: var(--red); color: var(--white); transform: rotate(-8deg); }
  .faq details:hover summary > i b,
  .faq details[open] summary > i b { opacity: 1; scale: 1; }
  .faq details[open] summary > i::after { transform: rotate(0); }

  .faq-answer { position: relative; z-index: 1; display: grid; grid-template-rows: 0fr; transition: grid-template-rows 560ms var(--ease-out); }
  .faq details[open] .faq-answer { grid-template-rows: 1fr; }
  .faq-answer p { max-width: 48rem; min-height: 0; margin: 0; overflow: hidden; color: var(--text-muted); font-size: 0.92rem; line-height: 1.7; }
  .faq details[open] .faq-answer p { padding: 0 5rem 2rem 5.45rem; }

  @keyframes faq-orbit-turn { to { rotate: 360deg; } }

  @media (max-width: 63.99rem) {
    .faq-heading { grid-template-columns: 1fr; }
    .faq-heading > p { margin-top: 1.25rem; }
    .faq-orbit { top: 8rem; right: -7rem; }
  }

  @media (max-width: 47.99rem) {
    .faq-heading h2 { font-size: clamp(2.8rem, 13.5vw, 4.3rem); }
    .faq-list { gap: 0.6rem; margin-top: 3.5rem; }
    .faq details,
    .faq details[open] { border-radius: 1.4rem; }
    .faq summary { min-height: 5rem; grid-template-columns: 2.25rem minmax(0, 1fr) 2.4rem; gap: 0.65rem; padding: 0.7rem; }
    .faq summary > span { width: 2rem; }
    .faq summary > i { width: 2.2rem; }
    .faq summary strong { font-size: 1rem; }
    .faq details[open] .faq-answer p { padding: 0 1rem 1.5rem 3.65rem; }
    .faq-orbit { opacity: 0.36; }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-orbit::after,
    .faq-orbit > i,
    .faq-orbit > b { animation: none; }
    .faq details,
    .faq details::before,
    .faq summary > span,
    .faq summary > i::after,
    .faq summary > i b,
    .faq-answer { transition: none; }
    .faq details:hover,
    .faq details:focus-within { transform: none; }
  }
</style>
