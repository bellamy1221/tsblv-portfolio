---
import { problems } from '../data/home';
---

<section class="section problems" aria-labelledby="problems-title">
  <div class="site-container problems-layout">
    <div class="section-intro" data-reveal="mask">
      <p class="section-label">С чего начать</p>
      <h2 id="problems-title">Можно прийти даже без готового ТЗ</h2>
      <p>Расскажите, что сейчас не работает или чего не хватает. Я помогу разобраться и предложу понятный вариант решения.</p>
    </div>
    <ol class="problem-stack">
      {problems.map((problem) => <li data-reveal="soft"><span>{problem.id}</span><h3>{problem.title}</h3></li>)}
    </ol>
  </div>
</section>

<style>
  .problems-layout { display:grid; gap:2.5rem; }.section-intro p:last-child { max-width:29rem; margin:1.25rem 0 0; color:var(--muted); line-height:1.65; }.problem-stack { display:grid; gap:.6rem; margin:0; padding:0; list-style:none; }.problem-stack li { display:grid; grid-template-columns:2.5rem 1fr; align-items:center; gap:1rem; min-height:4.4rem; padding:1rem 1.2rem; border:1px solid var(--line); border-radius:1rem; background:color-mix(in srgb,var(--glass) 66%,transparent); box-shadow:0 .45rem 1.2rem rgba(54,43,89,.06); backdrop-filter:blur(9px); transition:border-color .25s ease,background .25s ease; }.problem-stack li:hover { border-color:color-mix(in srgb,var(--violet) 52%,transparent); background:color-mix(in srgb,var(--glass) 86%,transparent); }.problem-stack span { color:var(--violet); font-size:.62rem; font-weight:750; }.problem-stack h3 { margin:0; font-size:clamp(1rem,1.65vw,1.28rem); font-weight:600; letter-spacing:-.03em; }
  @media(min-width:64rem) { .problems-layout { grid-template-columns:.8fr 1.2fr; }.section-intro { position:sticky; top:6.5rem; align-self:start; }.problem-stack li:nth-child(even) { transform:translateX(1.5rem); } }
</style>
