---
import { problems } from '../data/home';
---

<section class="section problems" aria-labelledby="problems-title">
  <div class="site-container content-grid problems-layout">
    <div class="section-intro" data-motion="clip">
      <p class="section-label">С чего начать</p>
      <h2 id="problems-title">Можно прийти даже без готового ТЗ</h2>
      <p>Расскажите, что сейчас не работает или чего не хватает. Я помогу разобраться и предложу понятный вариант решения.</p>
    </div>

    <ol class="problem-stack" data-sequence>
      {problems.map((problem, index) => (
        <li data-motion="row" data-motion-delay={index * 60} data-pointer-light>
          <span>{problem.id}</span>
          <h3>{problem.title}</h3>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .problems {
    border-bottom: 1px solid var(--line);
  }

  .problems-layout {
    align-items: start;
  }

  .section-intro {
    grid-column: 1 / span 5;
  }

  .section-intro h2 {
    max-width: 40rem;
  }

  .section-intro > p:last-child {
    max-width: 29rem;
    margin: 1.25rem 0 0;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .problem-stack {
    display: flex;
    grid-column: 6 / -1;
    align-items: flex-start;
    flex-direction: column;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .problem-stack li {
    --pointer-x: 50%;
    --pointer-y: 50%;
    position: relative;
    display: grid;
    width: 100%;
    min-height: 4.8rem;
    grid-template-columns: 2.4rem 1fr;
    align-items: center;
    gap: 0.8rem;
    border-top: 1px solid var(--line);
    background: radial-gradient(circle 9rem at var(--pointer-x) var(--pointer-y), rgba(255, 255, 255, 0.5), transparent 72%);
    transition: width 460ms var(--ease-out), padding-left 460ms var(--ease-out), color 300ms ease, opacity 300ms ease, transform 460ms var(--ease-out);
  }

  :global(html[data-theme='dark']) .problem-stack li {
    background: radial-gradient(circle 9rem at var(--pointer-x) var(--pointer-y), rgba(255, 255, 255, 0.07), transparent 72%);
  }

  .problem-stack li::after {
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--red), rgba(247, 245, 239, 0.8), var(--yellow), transparent 82%);
    content: '';
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 620ms var(--ease-out);
  }

  .problem-stack li:nth-child(2) { width: 92%; }
  .problem-stack li:nth-child(3) { width: 97%; }
  .problem-stack li:nth-child(4) { width: 86%; }
  .problem-stack li:nth-child(5) { width: 95%; }
  .problem-stack li:nth-child(6) { width: 90%; border-bottom: 1px solid var(--line); }

  .problem-stack li:hover {
    width: 100%;
    padding-left: 0.55rem;
    color: var(--red);
  }

  .problem-stack li:hover::after {
    transform: scaleX(1);
  }

  .problem-stack:has(li:hover) li:not(:hover) {
    opacity: 0.72;
    transform: translateX(-0.2rem);
  }

  .problem-stack span {
    color: var(--text-muted);
    font-size: 0.6rem;
    font-weight: 740;
  }

  .problem-stack h3 {
    max-width: 42rem;
    margin: 0;
    font-size: clamp(1.25rem, 2.45vw, 2.35rem);
    font-weight: 540;
    line-height: 1.08;
    letter-spacing: -0.052em;
  }

  @media (min-width: 64rem) {
    .section-intro {
      position: sticky;
      top: 6.25rem;
    }
  }

  @media (max-width: 63.99rem) {
    .section-intro,
    .problem-stack {
      grid-column: 1 / -1;
    }

    .problem-stack {
      margin-top: 2.5rem;
    }
  }

  @media (max-width: 47.99rem) {
    .problem-stack li,
    .problem-stack li:nth-child(n) {
      width: 100%;
      min-height: 4.2rem;
    }

    .problem-stack h3 {
      font-size: clamp(1.15rem, 5.8vw, 1.65rem);
    }

    .problem-stack:has(li:hover) li:not(:hover) {
      opacity: 1;
      transform: none;
    }
  }
</style>
