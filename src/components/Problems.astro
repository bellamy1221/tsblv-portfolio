---
import { problems } from '../data/home';
---

<section class="section problems" aria-labelledby="problems-title">
  <div class="site-container content-grid problems-layout">
    <div class="section-intro" data-motion="clip">
      <p class="section-label">С чего начать</p>
      <h2 id="problems-title">Можно прийти даже без готового ТЗ</h2>
      <p>Расскажите, что сейчас не работает или чего не хватает. Я помогу разобраться и предложу понятный вариант решения.</p>
    </div>

    <ol class="problem-stack" data-sequence>
      {problems.map((problem, index) => (
        <li data-motion="fade-blur" data-motion-delay={index * 65}>
          <div class="problem-row tech-frame" data-pointer-light>
            <span>{problem.id}</span>
            <h3>{problem.title}</h3>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .problems-layout {
    align-items: start;
  }

  .section-intro {
    grid-column: 1 / span 5;
  }

  .section-intro p:last-child {
    max-width: 29rem;
    margin: 1.25rem 0 0;
    color: var(--text-muted);
    line-height: 1.65;
  }

  .problem-stack {
    position: relative;
    display: grid;
    grid-column: 6 / -1;
    gap: 0.65rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .problem-stack::before {
    position: absolute;
    top: 0.9rem;
    bottom: 0.9rem;
    left: 1.85rem;
    width: 1px;
    background: linear-gradient(to bottom, var(--flag-red), var(--ice) 48%, var(--flag-yellow));
    content: '';
    opacity: 0.7;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 1050ms var(--ease-out);
  }

  .problem-stack.is-sequence-visible::before {
    transform: scaleY(1);
  }

  .problem-row {
    --pointer-x: 50%;
    --pointer-y: 50%;
    position: relative;
    display: grid;
    min-height: 4.5rem;
    grid-template-columns: 2.5rem 1fr;
    align-items: center;
    gap: 1rem;
    overflow: hidden;
    padding: 1rem 1.2rem;
    border: 1px solid var(--line);
    border-radius: 0.85rem;
    background:
      radial-gradient(circle 9rem at var(--pointer-x) var(--pointer-y), rgba(255, 255, 255, 0.5), transparent 72%),
      var(--surface-glass);
    box-shadow: 0 0.45rem 1.2rem rgba(16, 18, 22, 0.05);
    backdrop-filter: blur(9px);
    transition: border-color 340ms var(--ease-out), box-shadow 340ms var(--ease-out), transform 340ms var(--ease-out);
  }

  html[data-theme='dark'] .problem-row {
    background:
      radial-gradient(circle 9rem at var(--pointer-x) var(--pointer-y), rgba(255, 255, 255, 0.08), transparent 72%),
      var(--surface-glass);
  }

  .problem-row:hover {
    border-color: var(--line-strong);
    box-shadow: 0 0.8rem 2rem rgba(16, 18, 22, 0.1);
    transform: translateY(-2px);
  }

  .problem-row > span {
    position: relative;
    z-index: 1;
    color: var(--flag-red);
    font-size: 0.62rem;
    font-weight: 750;
  }

  .problem-row h3 {
    position: relative;
    z-index: 1;
    margin: 0;
    font-size: clamp(1rem, 1.65vw, 1.28rem);
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  @media (min-width: 64rem) {
    .section-intro {
      position: sticky;
      top: 6.5rem;
    }
  }

  @media (max-width: 63.99rem) {
    .section-intro,
    .problem-stack {
      grid-column: 1 / -1;
    }

    .problem-stack {
      margin-top: 2.5rem;
    }
  }
</style>
