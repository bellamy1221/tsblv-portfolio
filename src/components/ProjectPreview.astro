---
import type { PreviewKind } from '../data/home';

interface Props { kind: PreviewKind; }
const { kind } = Astro.props;
---

<div class:list={['browser-preview', `browser-preview--${kind}`]} aria-hidden="true">
  <div class="browser-bar">
    <span class="browser-dots"><i></i><i></i><i></i></span>
    <span class="browser-address">
      {kind === 'expert' ? 'specialist.ru' : kind === 'local' ? 'local-service.ru' : 'workspace / leads'}
    </span>
  </div>

  {kind === 'expert' && (
    <div class="expert-screen">
      <div class="preview-header"><strong>Имя специалиста</strong><span>Подход</span><span>Консультации</span><b>Записаться</b></div>
      <div class="preview-main">
        <div class="expert-copy">
          <small>Частная практика · Москва</small>
          <p class="preview-heading">Помогаю принимать сложные решения спокойно и точно.</p>
          <p>Индивидуальные консультации с понятным планом работы.</p>
          <span class="preview-button">Выбрать время <span>↗</span></span>
        </div>
        <div class="expert-portrait">
          <svg viewBox="0 0 320 400" role="presentation">
            <path d="M51 365c17-88 55-132 112-132 58 0 94 44 106 132" fill="#274a3f"/>
            <circle cx="162" cy="146" r="70" fill="#e0bda7"/>
            <path d="M93 154c-5-73 28-113 78-113 55 0 79 51 66 123-23-12-43-38-49-67-17 34-49 55-95 57Z" fill="#302a29"/>
            <path d="M128 176c20 14 41 14 62 0" fill="none" stroke="#855e54" stroke-width="3" stroke-linecap="round"/>
          </svg>
          <span>01 / Знакомство</span>
        </div>
      </div>
    </div>
  )}

  {kind === 'local' && (
    <div class="local-screen">
      <div class="preview-header"><strong>ЛОКАЛЬНЫЙ СЕРВИС</strong><span>Услуги</span><span>Работы</span><b>Связаться</b></div>
      <div class="preview-main">
        <div class="local-copy">
          <small>Ремонт и обслуживание техники</small>
          <p class="preview-heading">Возвращаем технику в работу без лишнего ожидания.</p>
          <div class="local-actions"><span class="preview-button">Рассчитать стоимость</span><span>Ежедневно · 09:00–20:00</span></div>
        </div>
        <div class="local-visual">
          <svg viewBox="0 0 680 210" role="presentation">
            <path d="M20 166h640M74 166V78h127v88M233 166V35h214v131M481 166v-62h126v62" fill="none" stroke="currentColor" stroke-width="2"/>
            <path d="M275 166v-65h61v65M366 73h39v39h-39M107 105h50M510 129h67" fill="none" stroke="currentColor" stroke-width="2"/>
            <circle cx="170" cy="166" r="26" fill="#f2a65a"/><circle cx="509" cy="166" r="18" fill="#f2a65a"/>
          </svg>
          <div><span>Точно<br/><small>понятные этапы</small></span><span>Рядом<br/><small>прямой контакт</small></span></div>
        </div>
      </div>
    </div>
  )}

  {kind === 'leads' && (
    <div class="leads-screen">
      <div class="leads-nav"><strong>ts.</strong><i></i><i></i><i></i><i></i><span>ДЦ</span></div>
      <div class="preview-main">
        <div class="preview-header"><div><small>Рабочее пространство</small><p class="preview-heading">Заявки</p></div><span class="preview-button">+ Новая заявка</span></div>
        <div class="lead-metrics"><span><small>Новые</small><strong>—</strong><em>пример данных</em></span><span><small>В работе</small><strong>—</strong><em>пример данных</em></span><span><small>Конверсия</small><strong>—</strong><em>пример данных</em></span></div>
        <div class="lead-workspace">
          <div><div class="table-head"><span>Заявка</span><span>Статус</span><span>Следующий шаг</span></div><div class="table-row"><b>Заявка #184</b><i>Новая</i><span>Ответить · 12:30</span></div><div class="table-row"><b>Заявка #183</b><i>В работе</i><span>Отправить смету</span></div><div class="table-row"><b>Заявка #182</b><i>Встреча</i><span>Звонок · завтра</span></div></div>
          <div class="lead-chart"><small>Заявки за неделю</small><svg viewBox="0 0 220 95" role="presentation"><path d="M4 82 35 68 65 72 96 39 127 52 158 25 188 31 216 9" fill="none" stroke="currentColor" stroke-width="3"/><path d="M4 82 35 68 65 72 96 39 127 52 158 25 188 31 216 9V95H4Z" fill="currentColor" opacity=".1"/></svg></div>
        </div>
      </div>
    </div>
  )}
</div>

<style>
  .browser-preview { overflow: hidden; border: 1px solid rgba(255,255,255,.22); border-radius: clamp(1.1rem, 2.2vw, 2rem); box-shadow: 0 2rem 5rem rgba(0,0,0,.24); }
  .browser-bar { display: grid; min-height: 2.25rem; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 0 .85rem; border-bottom: 1px solid rgba(18,20,18,.12); background: rgba(245,244,240,.86); color: #7b7c76; font-size: .48rem; }
  .browser-dots { display: flex; gap: .28rem; }
  .browser-dots i { width: .38rem; height: .38rem; border-radius: 50%; background: #c6c5c0; }
  .browser-address { grid-column: 2; }
  .preview-button { display: inline-flex; width: max-content; align-items: center; }
  .expert-screen { min-height: clamp(19rem, 43vw, 35rem); padding: clamp(1.2rem, 2.5vw, 2.6rem); background: #e9e4d9; color: #19231f; }
  .expert-screen > .preview-header, .local-screen > .preview-header { display: flex; align-items: center; gap: clamp(.8rem, 2.4vw, 2rem); font-size: clamp(.42rem, .7vw, .68rem); }
  .expert-screen > .preview-header strong, .local-screen > .preview-header strong { margin-right: auto; font-size: clamp(.65rem, 1vw, 1rem); letter-spacing: -.04em; }
  .expert-screen > .preview-header b, .local-screen > .preview-header b { padding: .55rem .8rem; border: 1px solid currentColor; border-radius: 999px; }
  .expert-screen > .preview-main { display: grid; min-height: inherit; grid-template-columns: 1.12fr .88fr; align-items: center; gap: 2rem; }
  .expert-copy small, .local-copy small { font-size: clamp(.42rem, .65vw, .64rem); font-weight: 700; letter-spacing: .11em; text-transform: uppercase; }
  .expert-copy .preview-heading { max-width: 34rem; margin: 1rem 0; color: #19231f; font-family: Georgia, serif; font-size: clamp(1.55rem, 3.9vw, 3.7rem); font-weight: 400; line-height: .98; letter-spacing: -.05em; }
  .expert-copy p { max-width: 21rem; color: #59645f; font-size: clamp(.58rem, 1vw, .9rem); }
  .expert-copy .preview-button { margin-top: 1.1rem; padding: .7rem 1rem; border-radius: 999px; background: #274a3f; color: white; font-size: clamp(.5rem, .75vw, .7rem); }
  .expert-portrait { position: relative; align-self: end; max-height: 28rem; overflow: hidden; background: #d9d2c5; }
  .expert-portrait svg { display: block; width: 100%; max-height: 27rem; }
  .expert-portrait span { position: absolute; right: .75rem; bottom: .75rem; color: white; font-size: .48rem; letter-spacing: .1em; }
  .local-screen { min-height: clamp(19rem, 43vw, 35rem); padding: clamp(1.2rem, 2.5vw, 2.6rem); background: #192a4a; color: #f6f1e7; }
  .local-screen > .preview-header b { border-color: #f2a65a; color: #f2a65a; }
  .local-screen > .preview-main { display: grid; min-height: inherit; grid-template-rows: 1fr auto; padding-top: 2rem; }
  .local-copy .preview-heading { max-width: 48rem; margin: 1rem 0; font-size: clamp(1.65rem, 4.6vw, 4.4rem); font-weight: 560; line-height: .95; letter-spacing: -.06em; }
  .local-actions { display: flex; align-items: center; gap: 1.25rem; }
  .local-actions .preview-button { padding: .75rem 1rem; border-radius: .3rem; background: #f2a65a; color: #192a4a; font-size: clamp(.48rem, .75vw, .7rem); font-weight: 700; }
  .local-actions > span:last-child { color: #aeb8ca; font-size: clamp(.45rem, .7vw, .65rem); }
  .local-visual { display: grid; grid-template-columns: 1fr auto; align-items: end; color: #7f96be; }
  .local-visual svg { width: 100%; }
  .local-visual > div { display: flex; gap: 1.25rem; color: #f6f1e7; font-size: clamp(.65rem, 1vw, .95rem); font-weight: 650; }
  .local-visual small { color: #8fa0bf; font-size: .45rem; font-weight: 500; }
  .leads-screen { display: grid; min-height: clamp(19rem, 43vw, 35rem); grid-template-columns: clamp(2.3rem, 5vw, 4.4rem) 1fr; background: #f5f6f7; color: #1c232d; }
  .leads-nav { display: flex; align-items: center; flex-direction: column; gap: 1rem; padding: 1rem .4rem; border-right: 1px solid #dde0e4; background: #171d28; color: white; }
  .leads-nav strong { margin-bottom: 1rem; font-size: clamp(.6rem, 1vw, 1rem); }
  .leads-nav i { width: clamp(.7rem, 1.2vw, 1rem); height: clamp(.7rem, 1.2vw, 1rem); border: 1px solid #626a78; border-radius: .2rem; }
  .leads-nav span { display: grid; width: 1.4rem; height: 1.4rem; margin-top: auto; place-items: center; border-radius: 50%; background: #3157d5; font-size: .38rem; }
  .leads-screen > .preview-main { min-width: 0; padding: clamp(1rem, 2.4vw, 2.2rem); }
  .leads-screen .preview-header { display: flex; align-items: center; justify-content: space-between; }
  .leads-screen .preview-header small { color: #818994; font-size: clamp(.4rem, .65vw, .62rem); }
  .leads-screen .preview-heading { margin: .2rem 0 0; font-size: clamp(1.1rem, 2.2vw, 2rem); font-weight: 700; letter-spacing: -.04em; }
  .leads-screen .preview-header .preview-button { padding: .6rem .8rem; border-radius: .4rem; background: #3157d5; color: white; font-size: clamp(.42rem, .7vw, .64rem); }
  .lead-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: .6rem; margin-top: 1.25rem; }
  .lead-metrics > span { display: grid; gap: .35rem; padding: clamp(.65rem, 1.5vw, 1.2rem); border: 1px solid #e0e3e7; border-radius: .45rem; background: white; }
  .lead-metrics small { color: #818994; font-size: clamp(.38rem, .6vw, .58rem); }
  .lead-metrics strong { font-size: clamp(.9rem, 1.8vw, 1.7rem); }
  .lead-metrics em { color: #4d8a65; font-size: clamp(.35rem, .55vw, .52rem); font-style: normal; }
  .lead-workspace { display: grid; grid-template-columns: 1.45fr .55fr; gap: .6rem; margin-top: .6rem; }
  .lead-workspace > * { min-width: 0; border: 1px solid #e0e3e7; border-radius: .45rem; background: white; }
  .table-head, .table-row { display: grid; grid-template-columns: 1fr .75fr 1fr; gap: .4rem; padding: clamp(.45rem, 1vw, .75rem); border-bottom: 1px solid #e8eaed; font-size: clamp(.34rem, .6vw, .58rem); }
  .table-head { color: #8a919b; }
  .table-row i { width: max-content; padding: .2rem .35rem; border-radius: 999px; background: #eef1ff; color: #3157d5; font-style: normal; }
  .table-row span { color: #6e7681; }
  .lead-chart { padding: .75rem; color: #3157d5; }
  .lead-chart small { color: #747c87; font-size: clamp(.38rem, .6vw, .58rem); }
  .lead-chart svg { display: block; width: 100%; margin-top: 1rem; }
  @media (max-width: 35rem) {
    .expert-screen > .preview-main { grid-template-columns: 1.2fr .8fr; gap: .75rem; }
    .expert-screen > .preview-header span, .local-screen > .preview-header span { display: none; }
    .expert-copy p { display: none; }
    .local-visual { grid-template-columns: 1fr; }
    .local-visual > div { display: none; }
    .lead-workspace { grid-template-columns: 1fr; }
    .lead-chart { display: none; }
    .table-head, .table-row { grid-template-columns: 1fr .75fr; }
    .table-head span:last-child, .table-row span { display: none; }
  }
</style>
