---
import type { PreviewKind } from '../data/home';

interface Props { kind: PreviewKind; }
const { kind } = Astro.props;
---

<div class:list={['browser-preview', `browser-preview--${kind}`]} aria-hidden="true">
  <div class="browser-bar">
    <span class="browser-dots"><i></i><i></i><i></i></span>
    <span>{kind === 'expert' ? 'specialist.ru' : kind === 'local' ? 'local-service.ru' : 'workspace / leads'}</span>
  </div>

  {kind === 'expert' && (
    <div class="expert-screen">
      <div class="preview-nav"><strong>Имя специалиста</strong><span>Подход</span><span>Консультации</span><b>Записаться</b></div>
      <div class="expert-layout">
        <div class="expert-copy">
          <small>Частная практика · Москва</small>
          <p class="preview-heading">Помогаю принимать сложные решения спокойно и точно.</p>
          <p>Индивидуальные консультации с понятным планом работы.</p>
          <span class="preview-button">Выбрать время ↗</span>
        </div>
        <div class="expert-portrait">
          <svg viewBox="0 0 320 400" role="presentation">
            <path d="M51 365c17-88 55-132 112-132 58 0 94 44 106 132" fill="#30343a"/>
            <circle cx="162" cy="146" r="70" fill="#d8b7a2"/>
            <path d="M93 154c-5-73 28-113 78-113 55 0 79 51 66 123-23-12-43-38-49-67-17 34-49 55-95 57Z" fill="#27282a"/>
            <path d="M128 176c20 14 41 14 62 0" fill="none" stroke="#855e54" stroke-width="3" stroke-linecap="round"/>
          </svg>
          <span>01 / Знакомство</span>
        </div>
      </div>
    </div>
  )}

  {kind === 'local' && (
    <div class="local-screen">
      <div class="preview-nav"><strong>ЛОКАЛЬНЫЙ СЕРВИС</strong><span>Услуги</span><span>Работы</span><b>Связаться</b></div>
      <div class="local-layout">
        <small>Ремонт и обслуживание техники</small>
        <p class="preview-heading">Возвращаем технику в работу без лишнего ожидания.</p>
        <div class="local-actions"><span class="preview-button">Рассчитать стоимость</span><span>Ежедневно · 09:00–20:00</span></div>
        <svg class="local-drawing" viewBox="0 0 680 210" role="presentation">
          <path d="M20 166h640M74 166V78h127v88M233 166V35h214v131M481 166v-62h126v62" fill="none" stroke="currentColor" stroke-width="2"/>
          <path d="M275 166v-65h61v65M366 73h39v39h-39M107 105h50M510 129h67" fill="none" stroke="currentColor" stroke-width="2"/>
          <circle cx="170" cy="166" r="24" fill="#b51f2b"/><circle cx="509" cy="166" r="17" fill="#e4b91f"/>
        </svg>
        <div class="local-notes"><span>Точно<small>понятные этапы</small></span><span>Рядом<small>прямой контакт</small></span></div>
      </div>
    </div>
  )}

  {kind === 'leads' && (
    <div class="leads-screen">
      <aside class="leads-nav"><strong>ts.</strong><i></i><i></i><i></i><span>ДЦ</span></aside>
      <div class="leads-main">
        <div class="leads-heading"><div><small>Рабочее пространство</small><p>Заявки</p></div><span>+ Новая заявка</span></div>
        <div class="lead-summary"><span><small>Новые</small><b>—</b></span><span><small>В работе</small><b>—</b></span><span><small>Конверсия</small><b>—</b></span><em>пример данных</em></div>
        <div class="pipeline">
          <div class="pipeline-column"><strong>Новые <i>2</i></strong><span class="lead-card lead-card--moving"><b>Заявка #184</b><small>Ответить · 12:30</small></span><span class="lead-card"><b>Заявка #183</b><small>Уточнить задачу</small></span></div>
          <div class="pipeline-column"><strong>В работе <i>1</i></strong><span class="lead-card"><b>Заявка #182</b><small>Отправить смету</small></span></div>
          <div class="pipeline-column"><strong>Встреча <i>1</i></strong><span class="lead-card"><b>Заявка #181</b><small>Звонок · завтра</small></span></div>
          <div class="pipeline-side"><small>Интеграции</small><span>Почта</span><span>Telegram</span><svg viewBox="0 0 160 70"><path d="M3 61 25 47 48 52 70 28 92 36 116 19 139 24 157 7" fill="none" stroke="currentColor" stroke-width="2"/></svg></div>
        </div>
        <div class="automation-flow">
          <span>lead</span><i></i><span>CRM</span><i></i><span>automation</span><i></i><span>result</span><b></b>
        </div>
      </div>
    </div>
  )}
</div>

<style>
  .browser-preview {
    overflow: hidden;
    border: 1px solid rgba(247, 245, 239, 0.24);
    border-radius: 0.35rem;
    box-shadow: 0 2.5rem 6rem rgba(0, 0, 0, 0.3);
    transition: clip-path 900ms var(--ease-out), opacity 650ms ease;
  }

  :global(.sequence-ready .case-study) .browser-preview {
    clip-path: inset(0 0 100% 0);
    opacity: 0.35;
  }

  :global(.sequence-ready .case-study.is-sequence-visible) .browser-preview {
    clip-path: inset(0);
    opacity: 1;
  }

  .browser-bar {
    display: grid;
    min-height: 2.1rem;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 0.8rem;
    border-bottom: 1px solid rgba(17, 19, 23, 0.16);
    background: #e7e6e1;
    color: #77797d;
    font-size: 0.46rem;
    transition: transform 620ms 220ms var(--ease-out), opacity 420ms 220ms ease;
  }

  :global(.sequence-ready .case-study) .browser-bar { opacity: 0; transform: translateY(-100%); }
  :global(.sequence-ready .case-study.is-sequence-visible) .browser-bar { opacity: 1; transform: none; }

  .browser-bar > span:last-child { grid-column: 2; }
  .browser-dots { display: flex; gap: 0.25rem; }
  .browser-dots i { width: 0.34rem; height: 0.34rem; border-radius: 50%; background: #b1b2af; }

  .preview-nav {
    display: flex;
    align-items: center;
    gap: clamp(0.8rem, 2.2vw, 2rem);
    font-size: clamp(0.42rem, 0.7vw, 0.68rem);
  }

  .preview-nav strong { margin-right: auto; font-size: clamp(0.65rem, 1vw, 1rem); letter-spacing: -0.04em; }
  .preview-nav b { padding: 0.5rem 0.7rem; border: 1px solid currentColor; font-weight: 650; }

  .expert-screen {
    min-height: clamp(18rem, 32vw, 30rem);
    padding: clamp(1.2rem, 3vw, 3rem);
    background: #e9e5da;
    color: #1d2421;
  }

  .expert-layout {
    display: grid;
    min-height: clamp(16rem, 26vw, 24rem);
    grid-template-columns: 1.12fr 0.88fr;
    align-items: center;
    gap: clamp(1rem, 3vw, 3rem);
  }

  .expert-copy {
    transition: transform 820ms var(--ease-out), opacity 620ms ease;
  }

  :global(.sequence-ready .case-study:not(.is-sequence-visible)) .expert-copy {
    opacity: 0;
    transform: translateY(1.5rem);
  }

  :global(.case-study.is-sequence-visible) .expert-copy { transform: none; opacity: 1; }
  .expert-copy small, .local-layout > small { font-size: clamp(0.42rem, 0.65vw, 0.62rem); font-weight: 720; letter-spacing: 0.12em; text-transform: uppercase; }
  .expert-copy .preview-heading { max-width: 40rem; margin: 1rem 0; font-family: Georgia, serif; font-size: clamp(1.6rem, 3.6vw, 3.8rem); font-weight: 400; line-height: 0.94; letter-spacing: -0.06em; }
  .expert-copy > p:not(.preview-heading) { max-width: 22rem; color: #626963; font-size: clamp(0.58rem, 1vw, 0.9rem); }
  .preview-button { display: inline-flex; width: max-content; margin-top: 1rem; padding: 0.7rem 0.9rem; background: #30343a; color: #f7f5ef; font-size: clamp(0.48rem, 0.72vw, 0.68rem); }

  .expert-portrait {
    position: relative;
    align-self: end;
    overflow: hidden;
    background: #d2cdc2;
    transition: transform 900ms 120ms var(--ease-out);
  }

  :global(.sequence-ready .case-study:not(.is-sequence-visible)) .expert-portrait { transform: translateY(2rem); }

  :global(.case-study.is-sequence-visible) .expert-portrait { transform: none; }
  .expert-portrait svg { display: block; width: 100%; max-height: 24rem; }
  .expert-portrait span { position: absolute; right: 0.75rem; bottom: 0.75rem; color: white; font-size: 0.46rem; letter-spacing: 0.1em; }

  .local-screen {
    min-height: clamp(18rem, 31vw, 29rem);
    padding: clamp(1.2rem, 3vw, 3rem);
    background: #30343a;
    color: #f7f5ef;
  }

  .local-layout > small,
  .local-layout .preview-heading,
  .local-actions {
    transition: opacity 520ms ease, transform 720ms var(--ease-out);
  }

  :global(.sequence-ready .case-study:not(.is-sequence-visible)) .local-layout > small,
  :global(.sequence-ready .case-study:not(.is-sequence-visible)) .local-layout .preview-heading,
  :global(.sequence-ready .case-study:not(.is-sequence-visible)) .local-actions {
    opacity: 0;
    transform: translateX(-1rem);
  }

  .local-layout .preview-heading { transition-delay: 90ms; }
  .local-actions { transition-delay: 180ms; }
  :global(.case-study.is-sequence-visible) .local-layout > small,
  :global(.case-study.is-sequence-visible) .local-layout .preview-heading,
  :global(.case-study.is-sequence-visible) .local-actions { opacity: 1; transform: none; }

  .local-screen .preview-nav b { border-color: var(--yellow); color: var(--yellow); }
  .local-layout { position: relative; display: grid; min-height: clamp(15rem, 24vw, 22rem); align-content: start; padding-top: clamp(1.25rem, 2.5vw, 2.5rem); }
  .local-layout .preview-heading { max-width: 61rem; margin: 0.8rem 0; font-size: clamp(1.8rem, 4.6vw, 4.8rem); font-weight: 540; line-height: 0.9; letter-spacing: -0.07em; }
  .local-actions { display: flex; align-items: center; gap: 1rem; }
  .local-actions .preview-button { margin: 0; background: var(--yellow); color: #1b1d20; }
  .local-actions > span:last-child { color: rgba(247, 245, 239, 0.55); font-size: clamp(0.43rem, 0.68vw, 0.64rem); }
  .local-drawing { align-self: end; width: 100%; color: #777d85; transform: scaleX(0.92); transform-origin: left; transition: transform 1000ms var(--ease-out); }
  :global(.case-study.is-sequence-visible) .local-drawing { transform: scaleX(1); }
  .local-notes { position: absolute; right: 0; bottom: 0.8rem; display: flex; gap: 1.5rem; font-size: clamp(0.62rem, 1vw, 0.94rem); font-weight: 650; }
  .local-notes span { display: grid; gap: 0.2rem; }
  .local-notes small { color: rgba(247, 245, 239, 0.48); font-size: 0.46rem; font-weight: 500; }

  .leads-screen {
    display: grid;
    min-height: clamp(18rem, 30vw, 28rem);
    grid-template-columns: clamp(2.5rem, 5vw, 4.5rem) 1fr;
    background: #171a1f;
    color: #f3f2ee;
  }

  .leads-nav { display: flex; align-items: center; flex-direction: column; gap: 1rem; padding: 1rem 0.35rem; border-right: 1px solid rgba(247, 245, 239, 0.12); background: #0f1114; }
  .leads-nav strong { margin-bottom: 1rem; font-size: clamp(0.65rem, 1vw, 1rem); }
  .leads-nav i { width: clamp(0.7rem, 1.2vw, 1rem); height: clamp(0.7rem, 1.2vw, 1rem); border: 1px solid #575d65; }
  .leads-nav span { display: grid; width: 1.45rem; height: 1.45rem; margin-top: auto; place-items: center; background: var(--red); font-size: 0.38rem; }
  .leads-main { min-width: 0; padding: clamp(1rem, 2.6vw, 2.5rem); }
  .leads-heading { display: flex; align-items: center; justify-content: space-between; }
  .leads-heading small { color: #858a91; font-size: clamp(0.4rem, 0.65vw, 0.62rem); }
  .leads-heading p { margin: 0.18rem 0 0; font-size: clamp(1.1rem, 2.2vw, 2rem); font-weight: 720; }
  .leads-heading > span { padding: 0.55rem 0.75rem; border: 1px solid rgba(247, 245, 239, 0.22); font-size: clamp(0.42rem, 0.65vw, 0.62rem); }
  .lead-summary { position: relative; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; margin-top: 1.2rem; background: rgba(247, 245, 239, 0.12); }
  .lead-summary > span { display: grid; gap: 0.25rem; padding: clamp(0.65rem, 1.5vw, 1.2rem); background: #20242a; }
  .lead-summary small { color: #8c9198; font-size: clamp(0.38rem, 0.58vw, 0.56rem); }
  .lead-summary b { font-size: clamp(0.85rem, 1.6vw, 1.5rem); }
  .lead-summary em { position: absolute; right: 0.5rem; bottom: 0.35rem; color: var(--yellow); font-size: 0.38rem; font-style: normal; }
  .pipeline { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)) 0.7fr; gap: 0.55rem; margin-top: 0.65rem; }
  .pipeline-column, .pipeline-side { min-width: 0; min-height: clamp(8rem, 13vw, 12rem); padding: clamp(0.55rem, 1.1vw, 0.9rem); border: 1px solid rgba(247, 245, 239, 0.11); background: #1c2025; }
  .pipeline-column > strong { display: flex; justify-content: space-between; color: #aeb2b7; font-size: clamp(0.4rem, 0.65vw, 0.62rem); }
  .pipeline-column strong i { color: var(--yellow); font-style: normal; }
  .lead-card { display: grid; gap: 0.35rem; margin-top: 0.6rem; padding: clamp(0.55rem, 1vw, 0.8rem); border-left: 2px solid var(--red); background: #292e35; }
  .lead-card b { font-size: clamp(0.4rem, 0.66vw, 0.64rem); }
  .lead-card small { color: #9499a0; font-size: clamp(0.36rem, 0.55vw, 0.52rem); }
  .lead-card--moving { transition: transform 700ms var(--ease-out), border-color 400ms ease; }
  :global(.case-study.is-sequence-visible) .lead-card--moving,
  .browser-preview:hover .lead-card--moving { transform: translateX(calc(100% + 1.1rem)); border-color: var(--yellow); }
  .pipeline-side { display: grid; align-content: start; gap: 0.55rem; }
  .pipeline-side small { color: #8c9198; font-size: clamp(0.38rem, 0.58vw, 0.56rem); }
  .pipeline-side span { padding: 0.45rem; border: 1px solid rgba(247, 245, 239, 0.1); font-size: clamp(0.38rem, 0.58vw, 0.55rem); }
  .pipeline-side svg { width: 100%; margin-top: auto; color: var(--yellow); }

  .lead-summary > span,
  .pipeline-column,
  .pipeline-side {
    transition: opacity 480ms ease, transform 650ms var(--ease-out);
  }

  :global(.sequence-ready .case-study:not(.is-sequence-visible)) .lead-summary > span,
  :global(.sequence-ready .case-study:not(.is-sequence-visible)) .pipeline-column,
  :global(.sequence-ready .case-study:not(.is-sequence-visible)) .pipeline-side {
    opacity: 0;
    transform: translateY(0.75rem);
  }

  :global(.case-study.is-sequence-visible) .lead-summary > span,
  :global(.case-study.is-sequence-visible) .pipeline-column,
  :global(.case-study.is-sequence-visible) .pipeline-side {
    opacity: 1;
    transform: none;
  }

  :global(.case-study.is-sequence-visible) .lead-summary > span:nth-child(2),
  :global(.case-study.is-sequence-visible) .pipeline-column:nth-child(2) { transition-delay: 90ms; }
  :global(.case-study.is-sequence-visible) .lead-summary > span:nth-child(3),
  :global(.case-study.is-sequence-visible) .pipeline-column:nth-child(3) { transition-delay: 180ms; }
  :global(.case-study.is-sequence-visible) .pipeline-side { transition-delay: 260ms; }

  .automation-flow {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto 1fr auto 1fr auto;
    align-items: center;
    gap: 0.45rem;
    margin-top: 0.75rem;
    padding: 0.75rem;
    border: 1px solid rgba(247, 245, 239, 0.11);
    background: #15181d;
    overflow: hidden;
  }

  .automation-flow span {
    color: #aeb2b7;
    font-size: clamp(0.38rem, 0.58vw, 0.55rem);
    letter-spacing: 0.08em;
  }

  .automation-flow i {
    height: 1px;
    background: rgba(247, 245, 239, 0.2);
  }

  .automation-flow b {
    position: absolute;
    top: 50%;
    left: 1rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--red);
    box-shadow: 0 0 0.8rem rgba(181, 31, 43, 0.45);
    opacity: 0;
    transform: translateY(-50%);
  }

  :global(.case-study.is-sequence-visible) .automation-flow b {
    animation: system-signal 2.25s 1050ms var(--ease-out) both;
  }

  .browser-preview:hover .automation-flow b {
    animation: system-signal-hover 1.8s var(--ease-out) both;
  }

  @keyframes system-signal {
    0% { left: 1rem; opacity: 0; }
    8% { opacity: 1; }
    45% { background: var(--white); box-shadow: 0 0 0.8rem rgba(247, 245, 239, 0.38); }
    100% { left: calc(100% - 1.4rem); background: var(--yellow); opacity: 1; box-shadow: 0 0 0.8rem rgba(228, 185, 31, 0.4); }
  }

  @keyframes system-signal-hover {
    0% { left: 1rem; opacity: 1; }
    50% { background: var(--white); }
    100% { left: calc(100% - 1.4rem); background: var(--yellow); opacity: 1; }
  }

  @media (max-width: 35rem) {
    .preview-nav span { display: none; }
    .expert-layout { grid-template-columns: 1.1fr 0.9fr; gap: 0.75rem; }
    .expert-copy > p:not(.preview-heading) { display: none; }
    .local-notes { display: none; }
    .pipeline { grid-template-columns: repeat(3, 1fr); }
    .pipeline-side { display: none; }
    .lead-card--moving { transform: none !important; }
    .automation-flow { gap: 0.25rem; padding-inline: 0.45rem; }
    .automation-flow span { font-size: 0.34rem; }
  }
</style>
