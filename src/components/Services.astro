---
import { services } from '../data/home';
---

<section class="section" id="services" aria-labelledby="services-title">
  <div class="site-container services-layout">
    <div data-reveal>
      <p class="section-label">Услуги</p>
      <h2 id="services-title">Чем я занимаюсь</h2>
    </div>
    <ol class="services-list">
      {services.map((service) => (
        <li data-reveal>
          <span>{service.id}</span>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
          <i aria-hidden="true">↗</i>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .services-layout { display: grid; gap: 3rem; }
  .services-list { margin: 0; padding: 0; border-top: 1px solid var(--line-strong); list-style: none; }
  li { display: grid; grid-template-columns: 2.5rem minmax(8rem, .8fr) minmax(12rem, 1.2fr) auto; align-items: center; gap: 1.25rem; min-height: 7rem; border-bottom: 1px solid var(--line); transition: padding .25s ease, background .25s ease; }
  li:hover { padding-inline: 1rem; background: var(--paper-raised); }
  li > span { color: var(--accent); font-size: .65rem; font-weight: 700; }
  h3 { margin: 0; font-size: clamp(1.25rem, 2.2vw, 2rem); font-weight: 550; letter-spacing: -.04em; }
  p { max-width: 32rem; margin: 0; color: var(--muted); font-size: .9rem; line-height: 1.55; }
  i { color: var(--muted); font-style: normal; }
  @media (min-width: 64rem) { .services-layout { grid-template-columns: .55fr 1.45fr; } }
  @media (max-width: 47.99rem) { li { grid-template-columns: 2rem 1fr auto; gap: .75rem; padding-block: 1.35rem; } li p { grid-column: 2 / -1; } }
</style>
