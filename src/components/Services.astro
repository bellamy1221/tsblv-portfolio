---
import { services } from '../data/home';
---

<section class="section services" id="services" aria-labelledby="services-title">
  <div class="site-container content-grid services-heading" data-motion="clip">
    <p class="section-label">Услуги</p>
    <h2 id="services-title">Что могу сделать</h2>
  </div>

  <div class="site-container services-interactive" data-services>
    <div class="service-list" data-sequence>
      {services.map((service, index) => (
        <article class:list={['service-row', index === 0 && 'is-active']} id={service.anchor} data-service-row={service.anchor} data-motion="row">
          <button type="button" data-service-trigger={service.anchor} aria-pressed={index === 0 ? 'true' : 'false'}>
            <span>{service.id}</span>
            <strong>{service.title}</strong>
            <p>{service.description}</p>
          </button>
        </article>
      ))}
    </div>

    <div class="service-stage" data-service-stage aria-live="polite">
      <div class="service-visual is-active" data-service-visual="service-sites" aria-label="Схема сборки сайта">
        <span class="visual-caption">Структура страницы</span>
        <div class="site-demo"><i></i><header></header><main><b></b><b></b><b></b><em></em></main><footer></footer></div>
      </div>

      <div class="service-visual" data-service-visual="service-crm" aria-label="Связи в CRM">
        <span class="visual-caption">Клиенты и этапы</span>
        <svg class="crm-demo" viewBox="0 0 620 420" aria-hidden="true">
          <path d="M112 215 248 112 385 199 512 92M112 215l146 112 127-128 126 116" pathLength="1" />
          <circle cx="112" cy="215" r="38"/><circle cx="248" cy="112" r="28"/><circle cx="385" cy="199" r="43"/><circle cx="512" cy="92" r="24"/><circle cx="258" cy="327" r="31"/><circle cx="511" cy="315" r="34"/>
        </svg>
      </div>

      <div class="service-visual" data-service-visual="service-automation" aria-label="Автоматизированный сигнал между сервисами">
        <span class="visual-caption">Связанный сценарий</span>
        <div class="automation-demo"><span>Форма</span><i></i><span>CRM</span><i></i><span>Уведомление</span><b></b></div>
      </div>

      <div class="service-visual" data-service-visual="service-analytics" aria-label="Аналитическая панель">
        <span class="visual-caption">Понятный отчёт</span>
        <div class="analytics-demo"><header><span>Обращения</span><b>—</b><small>пример данных</small></header><div class="bars"><i></i><i></i><i></i><i></i><i></i><i></i></div><svg viewBox="0 0 520 150" aria-hidden="true"><path d="M6 130 85 102 162 112 238 65 316 80 395 38 514 12" pathLength="1"/></svg></div>
      </div>
    </div>
  </div>
</section>

<style>
  .services {
    border-bottom: 1px solid var(--line);
  }

  .services-heading {
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }

  .services-heading .section-label {
    grid-column: 1 / -1;
  }

  .services-heading h2 {
    grid-column: 1 / span 8;
  }

  .services-interactive {
    display: grid;
    grid-template-columns: minmax(20rem, 0.86fr) minmax(0, 1.14fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: stretch;
  }

  .service-list {
    border-top: 1px solid var(--line-strong);
  }

  .service-row {
    border-bottom: 1px solid var(--line);
  }

  .service-row button {
    display: grid;
    width: 100%;
    grid-template-columns: 2.4rem minmax(8rem, 0.72fr) 1fr;
    align-items: baseline;
    gap: 0.8rem;
    padding: 1.25rem 0;
    border: 0;
    background: transparent;
    color: var(--text);
    text-align: left;
    cursor: pointer;
    transition: padding-left 380ms var(--ease-out), color 280ms ease;
  }

  .service-row button > span {
    color: var(--text-muted);
    font-size: 0.59rem;
  }

  .service-row strong {
    font-size: clamp(1.2rem, 2.2vw, 2rem);
    font-weight: 570;
    letter-spacing: -0.052em;
  }

  .service-row p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .service-row.is-active button,
  .service-row button:hover,
  .service-row button:focus-visible {
    padding-left: 0.55rem;
    color: var(--red);
  }

  .service-row.is-active {
    border-bottom-color: var(--yellow);
  }

  .service-stage {
    position: relative;
    min-height: 31rem;
    overflow: hidden;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
    background: linear-gradient(145deg, color-mix(in srgb, var(--page) 92%, var(--metal)), var(--page));
  }

  .service-visual {
    position: absolute;
    inset: 0;
    overflow: hidden;
    padding: clamp(1.2rem, 3vw, 2.5rem);
    opacity: 0;
    pointer-events: none;
    transform: translateY(1rem);
    transition: opacity 400ms ease, transform 560ms var(--ease-out);
  }

  .service-visual.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: none;
  }

  .visual-caption {
    color: var(--text-muted);
    font-size: 0.59rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .site-demo {
    position: absolute;
    right: 12%;
    bottom: -4%;
    width: 72%;
    height: 78%;
    border: 1px solid var(--line-strong);
    background: var(--page);
    box-shadow: -1.5rem 1.5rem 0 color-mix(in srgb, var(--metal) 16%, transparent);
    transform: translateY(18%);
    transition: transform 800ms var(--ease-out);
  }

  .service-visual.is-active .site-demo { transform: none; }
  .site-demo > i { display: block; height: 1.4rem; border-bottom: 1px solid var(--line); }
  .site-demo header { width: 78%; height: 12%; margin: 9% auto 4%; background: var(--text); transform: scaleX(0); transform-origin: left; transition: transform 640ms 150ms var(--ease-out); }
  .service-visual.is-active .site-demo header { transform: scaleX(1); }
  .site-demo main { display: grid; width: 78%; grid-template-columns: repeat(3, 1fr); gap: 0.6rem; margin: 0 auto; }
  .site-demo main b { height: 5rem; border: 1px solid var(--line); transform: translateY(1rem); opacity: 0; transition: transform 520ms var(--ease-out), opacity 420ms ease; }
  .site-demo main b:nth-child(2) { transition-delay: 80ms; }
  .site-demo main b:nth-child(3) { transition-delay: 160ms; }
  .service-visual.is-active .site-demo main b { transform: none; opacity: 1; }
  .site-demo main em { grid-column: 1 / -1; height: 0.6rem; background: var(--red); transform: scaleX(0); transform-origin: left; transition: transform 650ms 240ms var(--ease-out); }
  .service-visual.is-active .site-demo main em { transform: scaleX(1); }
  .site-demo footer { position: absolute; right: 0; bottom: 0; left: 0; height: 13%; background: var(--metal); }

  .crm-demo {
    position: absolute;
    inset: 10% 5% 2%;
    width: 90%;
    height: 86%;
    overflow: visible;
  }

  .crm-demo path { fill: none; stroke: var(--line-strong); stroke-width: 1.5; stroke-dasharray: 1; stroke-dashoffset: 1; transition: stroke-dashoffset 900ms var(--ease-out); }
  .crm-demo circle { fill: var(--page); stroke: var(--line-strong); stroke-width: 1.5; transform: scale(0); transform-box: fill-box; transform-origin: center; transition: transform 480ms var(--ease-out), fill 360ms ease; }
  .service-visual.is-active .crm-demo path { stroke-dashoffset: 0; }
  .service-visual.is-active .crm-demo circle { transform: scale(1); }
  .service-visual.is-active .crm-demo circle:nth-of-type(3) { fill: var(--red); stroke: var(--red); }
  .service-visual.is-active .crm-demo circle:last-of-type { fill: var(--yellow); stroke: var(--yellow); }

  .automation-demo {
    position: absolute;
    inset: 22% 8% 10%;
    display: grid;
    grid-template-columns: 1fr 0.7fr 1fr 0.7fr 1.25fr;
    align-items: center;
  }

  .automation-demo span { display: grid; min-height: 6rem; place-items: center; border: 1px solid var(--line-strong); color: var(--text); font-size: clamp(0.7rem, 1vw, 0.9rem); }
  .automation-demo i { height: 1px; background: var(--line-strong); transform: scaleX(0); transition: transform 620ms var(--ease-out); }
  .service-visual.is-active .automation-demo i { transform: scaleX(1); }
  .automation-demo b { position: absolute; top: 50%; left: 16%; width: 0.65rem; height: 0.65rem; border-radius: 50%; background: var(--red); opacity: 0; }
  .service-visual.is-active .automation-demo b { opacity: 1; animation: automation-signal 2.2s 400ms var(--ease-out) both; }

  .analytics-demo { position: absolute; inset: 18% 9% 9%; display: grid; grid-template-columns: 0.72fr 1.28fr; grid-template-rows: auto 1fr; gap: 1rem; }
  .analytics-demo header { display: grid; align-content: start; gap: 0.5rem; padding: 1rem; border: 1px solid var(--line); }
  .analytics-demo header span, .analytics-demo header small { color: var(--text-muted); font-size: 0.58rem; }
  .analytics-demo header b { font-size: 3rem; }
  .bars { display: flex; align-items: end; justify-content: space-around; padding: 1rem; border: 1px solid var(--line); }
  .bars i { width: 9%; background: var(--text); transform: scaleY(0); transform-origin: bottom; transition: transform 600ms var(--ease-out); }
  .bars i:nth-child(1) { height: 32%; } .bars i:nth-child(2) { height: 58%; } .bars i:nth-child(3) { height: 45%; background: var(--red); } .bars i:nth-child(4) { height: 72%; } .bars i:nth-child(5) { height: 63%; } .bars i:nth-child(6) { height: 88%; background: var(--yellow); }
  .service-visual.is-active .bars i { transform: scaleY(1); }
  .analytics-demo svg { grid-column: 1 / -1; width: 100%; height: 100%; }
  .analytics-demo svg path { fill: none; stroke: var(--text); stroke-width: 2; stroke-dasharray: 1; stroke-dashoffset: 1; pathLength: 1; transition: stroke-dashoffset 900ms 180ms var(--ease-out); }
  .service-visual.is-active .analytics-demo svg path { stroke-dashoffset: 0; }

  @keyframes automation-signal {
    0% { left: 16%; }
    45% { left: 49%; background: var(--white); }
    100% { left: 84%; background: var(--yellow); }
  }

  @media (max-width: 63.99rem) {
    .services-interactive { grid-template-columns: 1fr; gap: 2rem; }
    .service-stage { min-height: 27rem; }
  }

  @media (max-width: 47.99rem) {
    .services-heading h2 { font-size: clamp(2.8rem, 14vw, 4.5rem); }
    .service-row button { grid-template-columns: 2rem 1fr; }
    .service-row p { grid-column: 2; }
    .service-stage { width: 100%; min-height: 21rem; margin: 0.75rem 0 1.25rem; }
    .service-list > .service-stage { display: block; }
    .automation-demo { grid-template-columns: 1fr 0.35fr 1fr 0.35fr 1.25fr; inset-inline: 4%; }
    .automation-demo span { min-height: 4.5rem; font-size: 0.58rem; }
    .analytics-demo { inset-inline: 4%; }
  }
</style>
