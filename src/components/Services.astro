---
import { services } from '../data/home';
---

<section class="section services" id="services" aria-labelledby="services-title">
  <div class="site-container">
    <div class="content-grid services-heading" data-motion="clip">
      <div>
        <p class="section-label">Услуги</p>
        <h2 id="services-title">Что могу сделать</h2>
      </div>
    </div>

    <div class="service-grid" data-sequence>
      {services.map((service, index) => (
        <article
          class="service-entry"
          id={service.anchor}
          data-motion="scale-depth"
          data-motion-delay={index * 70}
        >
          <a class="service-card tech-frame" href="#contact" data-service-card data-pointer-light>
            <div class:list={['service-diagram', `diagram-${service.visual}`]} aria-hidden="true">
              <span></span><i></i><b></b><em></em>
            </div>
            <div class="service-copy">
              <p>{service.id}</p>
              <h3>{service.title}</h3>
              <span>{service.description}</span>
            </div>
            <strong>Обсудить задачу <span aria-hidden="true">→</span></strong>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-heading > div {
    grid-column: 1 / span 8;
  }

  .services-heading {
    margin-bottom: clamp(2.5rem, 4vw, 3.8rem);
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.75rem, 1.3vw, 1.1rem);
  }

  .service-entry {
    min-width: 0;
  }

  .service-card {
    --pointer-x: 50%;
    --pointer-y: 50%;
    position: relative;
    display: grid;
    min-height: 18rem;
    height: 100%;
    grid-template-rows: 1fr auto auto;
    padding: 1.2rem;
    border: 1px solid var(--line);
    border-radius: 1rem;
    background:
      radial-gradient(circle 10rem at var(--pointer-x) var(--pointer-y), rgba(255, 255, 255, 0.52), transparent 70%),
      var(--surface-glass);
    box-shadow: 0 0.75rem 2rem rgba(16, 18, 22, 0.07);
    color: var(--text);
    text-decoration: none;
    backdrop-filter: blur(10px);
    transition: transform 380ms var(--ease-out), box-shadow 380ms var(--ease-out), border-color 380ms var(--ease-out);
  }

  html[data-theme='dark'] .service-card {
    background:
      radial-gradient(circle 10rem at var(--pointer-x) var(--pointer-y), rgba(255, 255, 255, 0.08), transparent 70%),
      var(--surface-glass);
  }

  .service-card:hover,
  .service-card:focus-visible,
  .service-entry.is-highlighted .service-card {
    border-color: color-mix(in srgb, var(--flag-yellow) 66%, var(--line));
    box-shadow: var(--shadow-lg);
    transform: translateY(-0.35rem);
  }

  .service-copy p {
    margin: 0 0 0.55rem;
    color: var(--flag-red);
    font-size: 0.62rem;
    font-weight: 750;
  }

  .service-copy h3 {
    margin: 0;
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.05em;
  }

  .service-copy > span {
    display: block;
    max-width: 20rem;
    margin-top: 0.65rem;
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  .service-card > strong {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.2rem;
    color: var(--text);
    font-size: 0.72rem;
  }

  .service-card > strong span {
    color: var(--flag-red);
    font-size: 1rem;
    transition: transform 320ms var(--ease-out);
  }

  .service-card:hover > strong span {
    transform: translateX(0.25rem);
  }

  .service-diagram {
    position: relative;
    min-height: 8rem;
    overflow: hidden;
  }

  .service-diagram span,
  .service-diagram i,
  .service-diagram b,
  .service-diagram em {
    position: absolute;
    display: block;
    font-style: normal;
    transition: transform 620ms var(--ease-out), opacity 500ms ease;
  }

  .diagram-site span {
    top: 10%;
    left: 6%;
    width: 70%;
    height: 57%;
    border: 1px solid var(--line-strong);
    border-radius: 0.45rem;
    transform: scaleX(0);
    transform-origin: left;
  }

  .diagram-site i {
    top: 24%;
    left: 16%;
    width: 34%;
    height: 0.38rem;
    background: var(--flag-red);
    transform: translateX(-0.8rem);
    opacity: 0;
  }

  .diagram-site b {
    top: 41%;
    left: 16%;
    width: 46%;
    height: 2px;
    background: var(--line-strong);
    transform: scaleX(0);
    transform-origin: left;
  }

  .diagram-site em {
    top: 56%;
    left: 16%;
    width: 19%;
    height: 14%;
    border-radius: 0.25rem;
    background: var(--flag-yellow);
    transform: translateY(0.5rem);
    opacity: 0;
  }

  .diagram-crm span,
  .diagram-crm i,
  .diagram-crm b {
    width: 2.75rem;
    aspect-ratio: 1;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    background: var(--surface-glass-strong);
    transform: scale(0.72);
    opacity: 0;
  }

  .diagram-crm span { top: 17%; left: 8%; }
  .diagram-crm i { right: 10%; bottom: 14%; }
  .diagram-crm b { top: 7%; right: 26%; width: 1.7rem; border-color: rgba(220, 52, 65, 0.46); }

  .diagram-crm em {
    top: 42%;
    left: 27%;
    width: 48%;
    height: 1px;
    background: linear-gradient(90deg, var(--flag-red), var(--ice), var(--flag-yellow));
    transform: rotate(24deg) scaleX(0);
    transform-origin: left;
  }

  .diagram-auto::before,
  .diagram-auto::after {
    position: absolute;
    width: 22%;
    height: 26%;
    border: 1px solid var(--line-strong);
    border-radius: 0.35rem;
    content: '';
  }

  .diagram-auto::before { top: 13%; left: 6%; }
  .diagram-auto::after { right: 6%; bottom: 12%; }

  .diagram-auto span,
  .diagram-auto i,
  .diagram-auto b {
    height: 0.7rem;
    border-radius: 999px;
    transform: scaleX(0);
    transform-origin: left;
  }

  .diagram-auto span { top: 23%; left: 10%; width: 17%; background: var(--flag-red); }
  .diagram-auto i { top: 47%; left: 36%; width: 28%; background: var(--ice); }
  .diagram-auto b { right: 10%; bottom: 23%; width: 17%; background: var(--flag-yellow); }

  .diagram-auto em {
    top: 27%;
    left: 27%;
    width: 49%;
    height: 39%;
    border-top: 1px dashed var(--steel);
    border-right: 1px dashed var(--steel);
    transform: skewY(-18deg);
    opacity: 0.5;
  }

  .diagram-analytics span {
    right: 8%;
    bottom: 17%;
    left: 8%;
    height: 1px;
    background: var(--line-strong);
  }

  .diagram-analytics i,
  .diagram-analytics b,
  .diagram-analytics em {
    bottom: 17%;
    width: 13%;
    border-radius: 0.25rem 0.25rem 0 0;
    transform: scaleY(0);
    transform-origin: bottom;
  }

  .diagram-analytics i { left: 16%; height: 28%; background: var(--ice); }
  .diagram-analytics b { left: 43%; height: 51%; background: var(--flag-red); }
  .diagram-analytics em { right: 16%; height: 72%; background: var(--flag-yellow); }

  .service-grid.is-sequence-visible .diagram-site span,
  .service-card:hover .diagram-site span,
  .service-grid.is-sequence-visible .diagram-site b,
  .service-card:hover .diagram-site b,
  .service-grid.is-sequence-visible .diagram-auto span,
  .service-grid.is-sequence-visible .diagram-auto i,
  .service-grid.is-sequence-visible .diagram-auto b,
  .service-card:hover .diagram-auto span,
  .service-card:hover .diagram-auto i,
  .service-card:hover .diagram-auto b {
    transform: scale(1);
  }

  .service-grid.is-sequence-visible .diagram-site i,
  .service-grid.is-sequence-visible .diagram-site em,
  .service-card:hover .diagram-site i,
  .service-card:hover .diagram-site em {
    transform: none;
    opacity: 1;
  }

  .service-grid.is-sequence-visible .diagram-crm span,
  .service-grid.is-sequence-visible .diagram-crm i,
  .service-grid.is-sequence-visible .diagram-crm b,
  .service-card:hover .diagram-crm span,
  .service-card:hover .diagram-crm i,
  .service-card:hover .diagram-crm b {
    transform: scale(1);
    opacity: 1;
  }

  .service-grid.is-sequence-visible .diagram-crm em,
  .service-card:hover .diagram-crm em {
    transform: rotate(24deg) scaleX(1);
  }

  .service-grid.is-sequence-visible .diagram-analytics i,
  .service-grid.is-sequence-visible .diagram-analytics b,
  .service-grid.is-sequence-visible .diagram-analytics em,
  .service-card:hover .diagram-analytics i,
  .service-card:hover .diagram-analytics b,
  .service-card:hover .diagram-analytics em {
    transform: scaleY(1);
  }

  .service-grid.is-sequence-visible .service-entry:nth-child(2) .service-diagram *,
  .service-grid.is-sequence-visible .service-entry:nth-child(2) .service-diagram::before {
    transition-delay: 100ms;
  }

  .service-grid.is-sequence-visible .service-entry:nth-child(3) .service-diagram * {
    transition-delay: 170ms;
  }

  .service-grid.is-sequence-visible .service-entry:nth-child(4) .service-diagram * {
    transition-delay: 240ms;
  }

  .service-entry.is-highlighted .service-card {
    animation: service-highlight 1.15s var(--ease-out);
  }

  @keyframes service-highlight {
    50% {
      box-shadow: 0 0 0 0.3rem rgba(240, 201, 40, 0.22), var(--shadow-lg);
    }
  }

  @media (max-width: 63.99rem) {
    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 35rem) {
    .service-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      min-height: 17rem;
    }
  }
</style>
