---
import BrandMark from './BrandMark.astro';
import { siteConfig } from '../config/site';
---

<header class="site-header" data-site-header>
  <div class="header-shell">
    <BrandMark variant="wordmark" size="small" href="#top" ariaLabel="TSBLV — в начало страницы" />

    <nav class="desktop-nav" aria-label="Основная навигация">
      <ul>
        {siteConfig.navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <div class="header-actions">
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Включить тёмную тему" title="Включить тёмную тему">
        <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="3.25"></circle>
          <path d="M12 2.5v2M12 19.5v2M21.5 12h-2M4.5 12h-2M18.72 5.28l-1.42 1.42M6.7 17.3l-1.42 1.42M18.72 18.72l-1.42-1.42M6.7 6.7 5.28 5.28"></path>
        </svg>
        <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.2 15.2A8.5 8.5 0 0 1 8.8 3.8a8.5 8.5 0 1 0 11.4 11.4Z"></path>
        </svg>
      </button>
      <a class="header-cta" href="#contact">Написать</a>
      <button class="menu-button" type="button" aria-expanded="false" aria-controls="mobile-menu" data-menu-button>
        <span class="menu-icon" aria-hidden="true"><i></i><i></i></span>
        <span class="sr-only">Открыть меню</span>
      </button>
    </div>
  </div>

  <nav class="mobile-menu" id="mobile-menu" aria-label="Мобильная навигация" data-mobile-menu hidden>
    <ul>
      {siteConfig.navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
    </ul>
    <a class="mobile-contact" href="#contact">Обсудить задачу</a>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    z-index: 80;
    top: 0.7rem;
    left: 50%;
    width: min(calc(100% - 1.5rem), 64rem);
    transform: translateX(-50%);
    transition: top 320ms var(--ease-out), width 320ms var(--ease-out);
  }

  .header-shell,
  .mobile-menu {
    border: 1px solid var(--header-border);
    background: var(--header-surface);
    box-shadow: 0 0.75rem 2.2rem rgba(17, 19, 23, 0.11), inset 0 1px rgba(255, 255, 255, 0.66);
    backdrop-filter: blur(22px) saturate(125%);
    transition: background-color 520ms var(--ease-out), border-color 520ms var(--ease-out), box-shadow 520ms var(--ease-out);
  }

  .header-shell {
    display: flex;
    height: 3.25rem;
    align-items: center;
    gap: 1.25rem;
    padding: 0.35rem 0.55rem 0.35rem 1rem;
    border-radius: 0.8rem;
  }

  .site-header.is-scrolled {
    top: 0.45rem;
    width: min(calc(100% - 1.5rem), 61rem);
  }

  .header-shell :global(.brand-mark) {
    --brand-color: var(--text);
    --brand-line: var(--line-strong);
    --brand-muted: var(--text-muted);
  }

  .desktop-nav {
    margin-left: auto;
  }

  .desktop-nav ul {
    display: flex;
    gap: clamp(0.8rem, 1.8vw, 1.55rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .desktop-nav a,
  .header-cta,
  .mobile-menu a {
    color: var(--text);
    font-size: 0.71rem;
    font-weight: 700;
    text-decoration: none;
  }

  .desktop-nav a {
    position: relative;
    padding-block: 0.45rem;
  }

  .desktop-nav a::after {
    position: absolute;
    right: 0;
    bottom: 0.18rem;
    left: 0;
    height: 1px;
    background: var(--red);
    content: '';
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 320ms var(--ease-out);
  }

  .desktop-nav a:hover::after,
  .desktop-nav a:focus-visible::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .theme-toggle,
  .menu-button {
    position: relative;
    display: grid;
    width: 2.3rem;
    height: 2.3rem;
    place-items: center;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--text);
    cursor: pointer;
  }

  .theme-toggle::after,
  .menu-button::after {
    position: absolute;
    inset: 0.22rem;
    border: 1px solid transparent;
    content: '';
    transition: border-color 280ms ease;
  }

  .theme-toggle:hover::after,
  .menu-button:hover::after {
    border-color: var(--line-strong);
  }

  .theme-icon {
    position: absolute;
    width: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 1.6;
    transition: opacity 320ms ease, transform 380ms var(--ease-out);
  }

  .theme-icon--moon {
    opacity: 0;
    transform: scale(0.6) rotate(-25deg);
  }

  :global(html[data-theme='dark']) .theme-icon--sun {
    opacity: 0;
    transform: scale(0.6) rotate(25deg);
  }

  :global(html[data-theme='dark']) .theme-icon--moon {
    opacity: 1;
    transform: none;
  }

  .header-cta {
    margin-left: 0.2rem;
    padding: 0.65rem 0.85rem;
    border-left: 1px solid var(--line);
    transition: color 280ms ease;
  }

  .header-cta:hover,
  .header-cta:focus-visible {
    color: var(--red);
  }

  .menu-button,
  .mobile-menu {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  @media (max-width: 47.99rem) {
    .site-header {
      width: calc(100% - 1rem);
    }

    .desktop-nav,
    .header-cta {
      display: none;
    }

    .header-shell {
      height: 3.15rem;
      padding-left: 0.85rem;
    }

    .header-actions {
      margin-left: auto;
    }

    .menu-button {
      display: grid;
    }

    .menu-icon {
      display: grid;
      width: 1rem;
      gap: 0.25rem;
    }

    .menu-icon i {
      height: 1px;
      background: currentColor;
      transition: transform 320ms var(--ease-out);
    }

    .menu-button[aria-expanded='true'] i:first-child {
      transform: translateY(2.5px) rotate(45deg);
    }

    .menu-button[aria-expanded='true'] i:last-child {
      transform: translateY(-2.5px) rotate(-45deg);
    }

    .mobile-menu {
      gap: 0.8rem;
      margin-top: 0.35rem;
      padding: 0.8rem 1rem 1rem;
      border-radius: 0.65rem;
      opacity: 0;
      transform: translateY(-0.45rem);
      transition: opacity 280ms ease, transform 340ms var(--ease-out);
    }

    .mobile-menu.is-open {
      opacity: 1;
      transform: none;
    }

    .mobile-menu ul {
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .mobile-menu li + li {
      border-top: 1px solid var(--line);
    }

    .mobile-menu a {
      display: flex;
      min-height: 2.8rem;
      align-items: center;
      font-size: 0.86rem;
    }

    .mobile-contact {
      border-top: 1px solid var(--line-strong);
      color: var(--red) !important;
    }

    .mobile-menu[hidden] {
      display: none;
    }

    .mobile-menu:not([hidden]) {
      display: grid;
    }
  }
</style>
