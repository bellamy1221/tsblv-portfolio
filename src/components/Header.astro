---
import BrandMark from './BrandMark.astro';
import { siteConfig } from '../config/site';
---

<header class="site-header" data-site-header>
  <div class="header-shell">
    <BrandMark variant="wordmark" size="small" href="#top" ariaLabel="TSBLV — в начало страницы" />

    <nav class="desktop-nav" aria-label="Основная навигация">
      <ul>
        {siteConfig.navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <div class="header-actions">
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Включить тёмную тему" title="Включить тёмную тему">
        <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="12" cy="12" r="3.25"></circle>
          <path d="M12 2.5v2M12 19.5v2M21.5 12h-2M4.5 12h-2M18.72 5.28l-1.42 1.42M6.7 17.3l-1.42 1.42M18.72 18.72l-1.42-1.42M6.7 6.7 5.28 5.28"></path>
        </svg>
        <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20.2 15.2A8.5 8.5 0 0 1 8.8 3.8a8.5 8.5 0 1 0 11.4 11.4Z"></path>
        </svg>
      </button>
      <a class="header-cta" href="#contact">Написать</a>
      <button class="menu-button" type="button" aria-expanded="false" aria-controls="mobile-menu" data-menu-button>
        <span class="menu-icon" aria-hidden="true"><i></i><i></i></span>
        <span class="sr-only">Открыть меню</span>
      </button>
    </div>
  </div>

  <nav class="mobile-menu" id="mobile-menu" aria-label="Мобильная навигация" data-mobile-menu hidden>
    <ul>
      {siteConfig.navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
    </ul>
    <a class="button button-light" href="#contact">Обсудить задачу</a>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    z-index: 50;
    top: 0.7rem;
    left: 50%;
    width: min(calc(100% - 1.5rem), 64rem);
    transform: translateX(-50%);
    transition: top 340ms var(--ease-out), width 340ms var(--ease-out);
  }

  .header-shell,
  .mobile-menu {
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: linear-gradient(120deg, rgba(23, 26, 31, 0.52), rgba(16, 18, 22, 0.44));
    box-shadow: var(--shadow-sm), inset 0 1px 0 rgba(255, 255, 255, 0.34);
    backdrop-filter: blur(22px) saturate(125%);
  }

  .header-shell {
    display: flex;
    height: 3.35rem;
    align-items: center;
    gap: 1.35rem;
    padding: 0.35rem 0.48rem 0.35rem 1rem;
    border-radius: 1.05rem;
  }

  .header-shell::after {
    position: absolute;
    top: 1px;
    right: 12%;
    left: 12%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent);
    content: '';
    pointer-events: none;
  }

  .site-header.is-scrolled {
    top: 0.5rem;
    width: min(calc(100% - 1.5rem), 61.5rem);
  }

  .site-header.is-scrolled .header-shell {
    background: linear-gradient(120deg, rgba(23, 26, 31, 0.62), rgba(16, 18, 22, 0.54));
  }

  .header-shell :global(.brand-mark) {
    --brand-color: #f8fafb;
    --brand-muted: rgba(248, 250, 251, 0.66);
    --brand-line: rgba(255, 255, 255, 0.32);
  }

  .desktop-nav {
    margin-left: auto;
  }

  .desktop-nav ul {
    display: flex;
    gap: clamp(0.85rem, 2vw, 1.7rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .desktop-nav a {
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.73rem;
    font-weight: 700;
    text-decoration: none;
    transition: color 320ms var(--ease-out);
  }

  .desktop-nav a:hover,
  .desktop-nav a:focus-visible {
    color: #fff;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.42rem;
  }

  .theme-toggle,
  .menu-button {
    position: relative;
    display: grid;
    width: 2.4rem;
    height: 2.4rem;
    place-items: center;
    padding: 0;
    border: 1px solid rgba(255, 255, 255, 0.17);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    cursor: pointer;
    transition: transform 320ms var(--ease-out), background-color 320ms var(--ease-out), border-color 320ms var(--ease-out);
  }

  .theme-toggle:hover,
  .menu-button:hover {
    border-color: rgba(240, 201, 40, 0.5);
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-1px);
  }

  .theme-icon {
    position: absolute;
    width: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-width: 1.6;
    transition: opacity 320ms var(--ease-out), transform 380ms var(--ease-out);
  }

  .theme-icon--moon {
    opacity: 0;
    transform: scale(0.6) rotate(-25deg);
  }

  :global(html[data-theme='dark']) .theme-icon--sun {
    opacity: 0;
    transform: scale(0.6) rotate(25deg);
  }

  :global(html[data-theme='dark']) .theme-icon--moon {
    opacity: 1;
    transform: none;
  }

  .header-cta {
    padding: 0.66rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.12);
    color: #f8fafb;
    font-size: 0.7rem;
    font-weight: 760;
    text-decoration: none;
    transition: transform 320ms var(--ease-out), background-color 320ms var(--ease-out), border-color 320ms var(--ease-out);
  }

  .header-cta:hover {
    border-color: var(--flag-yellow);
    background: rgba(255, 255, 255, 0.18);
    transform: translateY(-1px);
  }

  .menu-button,
  .mobile-menu {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  @media (max-width: 47.99rem) {
    .site-header {
      top: 0.65rem;
      width: calc(100% - 1.5rem);
    }

    .desktop-nav,
    .header-cta {
      display: none;
    }

    .header-shell {
      height: 3.2rem;
      padding-left: 0.9rem;
    }

    .menu-button {
      display: grid;
    }

    .menu-icon {
      display: grid;
      width: 1rem;
      gap: 0.25rem;
    }

    .menu-icon i {
      display: block;
      height: 1px;
      background: currentColor;
      transition: transform 320ms var(--ease-out);
    }

    .menu-button[aria-expanded='true'] i:first-child {
      transform: translateY(2.5px) rotate(45deg);
    }

    .menu-button[aria-expanded='true'] i:last-child {
      transform: translateY(-2.5px) rotate(-45deg);
    }

    .mobile-menu {
      display: grid;
      gap: 0.8rem;
      margin-top: 0.45rem;
      padding: 1rem;
      border-radius: 1rem;
      opacity: 0;
      transform: translateY(-0.5rem) scale(0.985);
      transition: opacity 320ms var(--ease-out), transform 360ms var(--ease-out);
    }

    .mobile-menu.is-open {
      opacity: 1;
      transform: none;
    }

    .mobile-menu ul {
      display: grid;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .mobile-menu li + li {
      border-top: 1px solid rgba(255, 255, 255, 0.14);
    }

    .mobile-menu a:not(.button) {
      display: flex;
      min-height: 2.7rem;
      align-items: center;
      color: rgba(255, 255, 255, 0.9);
      font-size: 0.88rem;
      font-weight: 700;
      text-decoration: none;
    }

    .mobile-menu[hidden] {
      display: none;
    }
  }
</style>
