---
import BrandMark from './BrandMark.astro';
import { siteConfig } from '../config/site';
---

<header class="site-header" data-site-header>
  <div class="site-container header-inner">
    <BrandMark variant="wordmark" size="small" href="#top" ariaLabel="TSBLV — в начало страницы" />

    <nav class="desktop-nav" aria-label="Основная навигация">
      <ul>
        {siteConfig.navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <button class="theme-toggle" type="button" data-theme-toggle aria-label="Включить тёмную тему" title="Включить тёмную тему">
      <svg class="theme-icon theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3.25"></circle><path d="M12 2.5v2M12 19.5v2M21.5 12h-2M4.5 12h-2M18.72 5.28l-1.42 1.42M6.7 17.3l-1.42 1.42M18.72 18.72l-1.42-1.42M6.7 6.7 5.28 5.28"></path></svg>
      <svg class="theme-icon theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.2 15.2A8.5 8.5 0 0 1 8.8 3.8a8.5 8.5 0 1 0 11.4 11.4Z"></path></svg>
    </button>

    <a class="header-cta" href="#contact">Обсудить задачу</a>

    <button
      class="menu-button"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-button
    >
      <span>Меню</span>
      <span class="menu-icon" aria-hidden="true"><i></i><i></i></span>
    </button>
  </div>

  <nav class="mobile-menu" id="mobile-menu" aria-label="Мобильная навигация" data-mobile-menu hidden>
    <div class="site-container mobile-menu-inner">
      <ul>
        {siteConfig.navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
      <a class="button button-primary" href="#contact">Обсудить задачу</a>
    </div>
  </nav>
</header>

<style>
  .site-header { position: sticky; z-index: 50; top: 0; height: 4.5rem; border-bottom: 1px solid transparent; transition: background-color .25s ease, border-color .25s ease, backdrop-filter .25s ease; }
  .site-header.is-scrolled, .site-header.is-open { border-color: color-mix(in srgb, var(--line) 82%, transparent); background: color-mix(in srgb, var(--paper) 88%, transparent); backdrop-filter: blur(16px); }
  .header-inner { display: flex; height: 100%; align-items: center; justify-content: space-between; gap: 1.5rem; }
  ul { display: flex; align-items: center; gap: clamp(1.25rem, 2.2vw, 2.25rem); margin: 0; padding: 0; list-style: none; }
  .desktop-nav { margin-left: auto; }
  .desktop-nav a { position: relative; display: inline-flex; min-height: 2.75rem; align-items: center; color: var(--muted); font-size: .78rem; font-weight: 600; text-decoration: none; transition: color .2s ease; }
  .desktop-nav a::after { position: absolute; right: 0; bottom: .38rem; left: 0; height: 1px; background: var(--accent); content: ''; transform: scaleX(0); transform-origin: right; transition: transform .25s cubic-bezier(.22,1,.36,1); }
  .desktop-nav a:hover::after, .desktop-nav a:focus-visible::after { transform: scaleX(1); transform-origin: left; }
  .desktop-nav a:hover, .desktop-nav a:focus-visible { color: var(--ink); }
  .theme-toggle { display: grid; width: 2.65rem; height: 2.65rem; margin-left: clamp(.25rem, 1vw, .75rem); place-items: center; padding: 0; border: 1px solid var(--line-strong); border-radius: 50%; background: transparent; color: var(--ink); cursor: pointer; transition: border-color .2s ease, background .2s ease, transform .2s ease; }
  .theme-toggle:hover { border-color: var(--ink); background: var(--paper-raised); }
  .theme-toggle:active { transform: scale(.93); }
  .theme-icon { position: absolute; width: .95rem; height: .95rem; fill: none; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 1.55; transition: opacity .18s ease, transform .25s cubic-bezier(.22,1,.36,1); }
  .theme-icon--moon { opacity: 0; transform: rotate(-30deg) scale(.65); }
  :global(html[data-theme='dark']) .theme-icon--sun { opacity: 0; transform: rotate(30deg) scale(.65); }
  :global(html[data-theme='dark']) .theme-icon--moon { opacity: 1; transform: none; }
  .header-cta { display: inline-flex; min-height: 2.65rem; align-items: center; padding: 0 1rem; border: 1px solid var(--ink); border-radius: 999px; color: var(--ink); font-size: .76rem; font-weight: 650; text-decoration: none; transition: background .2s ease, color .2s ease, transform .2s ease; }
  .header-cta:hover { background: var(--ink); color: var(--paper); }
  .header-cta:active { transform: scale(.97); }
  .menu-button, .mobile-menu { display: none; }
  @media (max-width: 47.99rem) {
    .site-header { height: 4rem; }
    .desktop-nav, .header-cta { display: none; }
    .theme-toggle { width: 2.5rem; height: 2.5rem; margin-left: auto; }
    .menu-button { display: inline-flex; min-width: 5.25rem; min-height: 2.75rem; align-items: center; justify-content: flex-end; gap: .7rem; padding: 0; border: 0; background: transparent; color: var(--ink); font: inherit; font-size: .78rem; font-weight: 650; }
    .menu-icon { position: relative; display: grid; width: 1rem; gap: .25rem; }
    .menu-icon i { display: block; width: 100%; height: 1px; background: currentColor; transition: transform .2s ease; }
    .menu-button[aria-expanded='true'] .menu-icon i:first-child { transform: translateY(2.5px) rotate(45deg); }
    .menu-button[aria-expanded='true'] .menu-icon i:last-child { transform: translateY(-2.5px) rotate(-45deg); }
    .mobile-menu { position: absolute; top: 100%; left: 0; display: block; width: 100%; border-bottom: 1px solid var(--line); background: var(--paper); opacity: 0; transform: translateY(-.5rem); transition: opacity .18s ease, transform .18s ease; }
    .mobile-menu[hidden] { display: none; }
    .mobile-menu.is-open { opacity: 1; transform: none; }
    .mobile-menu-inner { padding-block: 1rem 1.5rem; }
    .mobile-menu ul { display: grid; gap: 0; }
    .mobile-menu li { border-bottom: 1px solid var(--line); }
    .mobile-menu a:not(.button) { display: flex; min-height: 3.25rem; align-items: center; color: var(--ink); font-size: 1rem; font-weight: 620; text-decoration: none; }
    .mobile-menu .button { width: 100%; margin-top: 1rem; }
  }
</style>
