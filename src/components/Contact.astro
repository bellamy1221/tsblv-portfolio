---
import { siteConfig } from '../config/site';
---
<section class="section contact" id="contact" aria-labelledby="contact-title">
  <div class="contact-light contact-light-one"></div><div class="contact-light contact-light-two"></div>
  <div class="site-container contact-inner" data-reveal="depth"><p class="section-label">Следующий шаг</p><h2 id="contact-title">Расскажите, что хотите сделать</h2><p>Можно написать даже с сырой идеей. Я задам несколько вопросов и предложу, с чего лучше начать.</p><div class="contact-actions"><a class="button button-light" href={siteConfig.telegramUrl} target="_blank" rel="noreferrer">Написать в Telegram</a><a class="button button-outline-light" href={`mailto:${siteConfig.email}`}>Написать на почту</a></div></div>
</section>
<style>
  .contact { position:relative; overflow:hidden; color:var(--on-accent); }.contact::before { position:absolute; inset:0; background:radial-gradient(circle at 82% 18%,color-mix(in srgb,var(--lavender) 76%,transparent),transparent 32%),radial-gradient(circle at 18% 85%,color-mix(in srgb,var(--peach) 58%,transparent),transparent 38%),linear-gradient(135deg,rgba(42,32,61,.9),rgba(33,56,68,.8) 55%,rgba(83,47,62,.83)); content:''; }.contact::after { position:absolute; inset:1rem; border:1px solid rgba(255,255,255,.18); border-radius:1.6rem; content:''; }.contact-light { position:absolute; border-radius:50%; filter:blur(16px); opacity:.65; }.contact-light-one { top:-24%; right:-5%; width:43vw; aspect-ratio:1; background:var(--lavender); }.contact-light-two { bottom:-38%; left:12%; width:42vw; aspect-ratio:1; background:var(--peach); }.contact-inner { position:relative; z-index:1; }.section-label { color:#d9d1ff; }.contact h2 { max-width:60rem; font-size:clamp(2.65rem,6.2vw,6.2rem); }.contact p:not(.section-label) { max-width:37rem; margin:1.5rem 0 0; color:rgba(255,255,255,.84); font-size:clamp(1rem,1.5vw,1.2rem); line-height:1.6; }.contact-actions { display:flex; flex-wrap:wrap; gap:.7rem; margin-top:1.8rem; }@media(max-width:35rem) { .contact-actions { display:grid; }.contact::after { inset:.5rem; } }
</style>
