---
import { siteConfig } from '../config/site';
---

<section class="section contact" id="contact" aria-labelledby="contact-title">
  <div class="site-container contact-inner" data-reveal>
    <p class="section-label">Следующий шаг</p>
    <h2 id="contact-title">Есть задача? Давайте найдём для неё подходящее решение.</h2>
    <p>Коротко расскажите, что хотите сделать. Я изучу задачу и предложу следующий шаг.</p>
    <div class="contact-actions">
      <a class="button button-light" href={siteConfig.telegramUrl} target="_blank" rel="noreferrer">Написать в Telegram</a>
      <a class="button button-outline-light" href={`mailto:${siteConfig.email}`}>Написать на почту</a>
    </div>
  </div>
</section>

<style>
  .contact { position: relative; overflow: hidden; background: var(--accent); color: var(--on-accent); }
  .contact::after { position: absolute; right: -12vw; bottom: -26vw; width: 55vw; height: 55vw; border: 1px solid rgba(255,255,255,.22); border-radius: 50%; content: ''; }
  .contact-inner { position: relative; z-index: 1; }
  .section-label { color: #cbd5ff; }
  h2 { max-width: 68rem; font-size: clamp(2.5rem, 6.7vw, 6.7rem); line-height: .98; }
  p:not(.section-label) { max-width: 36rem; margin: 2rem 0 0; color: #dce3ff; font-size: clamp(1rem, 1.5vw, 1.2rem); line-height: 1.55; }
  .contact-actions { display: flex; flex-wrap: wrap; gap: .65rem; margin-top: 2rem; }
  @media (max-width: 35rem) { .contact-actions { display: grid; } }
</style>
