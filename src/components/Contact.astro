---
import { siteConfig } from '../config/site';
---

<section class="contact" id="contact" aria-labelledby="contact-title" data-pointer-light data-sequence>
  <div class="site-container contact-inner">
    <p class="section-label" data-motion="row">Следующий шаг</p>
    <h2 id="contact-title" data-motion="clip"><span>Есть идея?</span><span>Давайте превратим её в работающий проект.</span></h2>
    <div class="content-grid contact-bottom" data-motion="text">
      <p>Можно написать даже с сырой идеей. Я задам несколько вопросов и предложу, с чего лучше начать.</p>
      <div class="contact-actions">
        <a class="button button-light" href={siteConfig.telegramUrl} target="_blank" rel="noreferrer">Написать в Telegram</a>
        <a class="button button-outline-light" href={`mailto:${siteConfig.email}`}>Написать на почту</a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    --pointer-x: 68%;
    --pointer-y: 42%;
    position: relative;
    overflow: hidden;
    padding: clamp(7rem, 12vw, 12rem) 0 clamp(5rem, 8vw, 8rem);
    color: var(--white);
    background:
      radial-gradient(ellipse 34% 52% at var(--pointer-x) var(--pointer-y), rgba(255, 255, 255, 0.12), transparent 68%),
      conic-gradient(from 218deg at 72% 48%, transparent 0 27%, rgba(181, 31, 43, 0.13) 34%, rgba(247, 245, 239, 0.11) 40%, rgba(228, 185, 31, 0.12) 46%, transparent 54% 100%),
      linear-gradient(to bottom, transparent, var(--dark) 12rem, var(--dark));
  }

  .contact::before {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 35%, rgba(255, 255, 255, 0.12) 49%, transparent 63%);
    background-position: 130% 0;
    background-size: 220% 100%;
    content: '';
    pointer-events: none;
  }

  .contact.is-sequence-visible::before {
    animation: contact-sweep 2.2s 300ms var(--ease-out) both;
  }

  .contact-inner {
    position: relative;
  }

  .contact .section-label {
    color: var(--yellow);
  }

  .contact h2 {
    display: grid;
    max-width: 88rem;
    font-size: clamp(4rem, 10.5vw, 11.5rem);
    line-height: 0.82;
    letter-spacing: -0.085em;
  }

  .contact h2 span:first-child {
    color: rgba(247, 245, 239, 0.46);
  }

  .contact h2 span:last-child {
    padding-left: 8vw;
  }

  .contact-bottom {
    align-items: end;
    margin-top: clamp(2.5rem, 6vw, 5rem);
    padding-top: 1.25rem;
    border-top: 1px solid var(--line-dark);
  }

  .contact-bottom > p {
    grid-column: 1 / span 5;
    max-width: 34rem;
    margin: 0;
    color: rgba(247, 245, 239, 0.68);
    font-size: clamp(0.92rem, 1.3vw, 1.1rem);
    line-height: 1.62;
  }

  .contact-actions {
    display: flex;
    grid-column: 8 / -1;
    justify-content: flex-end;
    gap: 0.65rem;
  }

  @keyframes contact-sweep {
    to { background-position: -25% 0; }
  }

  @media (max-width: 63.99rem) {
    .contact h2 span:last-child { padding-left: 0; }
    .contact-bottom > p,
    .contact-actions { grid-column: 1 / -1; }
    .contact-actions { justify-content: flex-start; margin-top: 1.75rem; }
  }

  @media (max-width: 47.99rem) {
    .contact { padding-top: 5rem; }
    .contact h2 { font-size: clamp(3.5rem, 18vw, 6rem); }
    .contact-actions { align-items: stretch; flex-direction: column; }
  }
</style>
