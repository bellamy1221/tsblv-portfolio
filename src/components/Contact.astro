---
import { siteConfig } from '../config/site';
---
<section class="section contact" id="contact" aria-labelledby="contact-title">
  <div class="contact-light contact-light-one"></div><div class="contact-light contact-light-two"></div>
  <div class="site-container contact-inner tech-frame" data-reveal="depth"><p class="section-label">Следующий шаг</p><h2 id="contact-title">Расскажите, что хотите сделать</h2><p>Можно написать даже с сырой идеей. Я задам несколько вопросов и предложу, с чего лучше начать.</p><div class="contact-actions"><a class="button button-light" href={siteConfig.telegramUrl} target="_blank" rel="noreferrer">Написать в Telegram</a><a class="button button-outline-light" href={`mailto:${siteConfig.email}`}>Написать на почту</a></div></div>
</section>
<style>
  .contact { position:relative; overflow:hidden; color:var(--on-accent); }.contact::before { position:absolute; inset:-8% 0; background:radial-gradient(ellipse at 88% 14%,color-mix(in srgb,var(--cyan) 42%,transparent),transparent 34%),radial-gradient(ellipse at 12% 90%,color-mix(in srgb,var(--signal-yellow) 10%,transparent),transparent 36%),linear-gradient(135deg,rgba(7,21,34,.94),rgba(17,34,48,.86) 55%,rgba(15,22,31,.94)); content:''; }.contact::after { position:absolute; inset:1rem; border:1px solid rgba(255,255,255,.18); border-radius:1.1rem; content:''; }.contact-light { position:absolute; border-radius:50%; filter:blur(16px); opacity:.48; }.contact-light-one { top:-24%; right:-5%; width:43vw; aspect-ratio:1; background:var(--cyan); }.contact-light-two { bottom:-38%; left:12%; width:42vw; aspect-ratio:1; background:var(--signal-yellow); opacity:.14; }.contact-inner { position:relative; z-index:1; }.section-label { color:var(--cyan); }.contact h2 { max-width:60rem; font-size:clamp(2.65rem,6.2vw,6.2rem); }.contact p:not(.section-label) { max-width:37rem; margin:1.5rem 0 0; color:rgba(255,255,255,.84); font-size:clamp(1rem,1.5vw,1.2rem); line-height:1.6; }.contact-actions { display:flex; flex-wrap:wrap; gap:.7rem; margin-top:1.8rem; }@media(max-width:35rem) { .contact-actions { display:grid; }.contact::after { inset:.5rem; } }
</style>
