---
import HeroVisual from './HeroVisual.astro';
---

<section class="hero" id="hero" aria-labelledby="hero-title">
  <div class="hero-container hero-inner">
    <div class="hero-content">
      <p class="eyebrow" data-hero-item="eyebrow">Независимая digital-студия</p>
      <h1 id="hero-title">
        <span class="hero-title-line" data-hero-line="1">
          <span class="hero-title-line-inner">От ясных систем</span>
        </span>
        <span class="hero-title-line" data-hero-line="2">
          <span class="hero-title-line-inner">до выразительных</span>
        </span>
        <span class="hero-title-line hero-title-line--desktop" data-hero-line="3">
          <span class="hero-title-line-inner">цифровых миров</span>
        </span>
        <span class="hero-title-line hero-title-line--mobile" data-hero-line="3a">
          <span class="hero-title-line-inner">цифровых</span>
        </span>
        <span class="hero-title-line hero-title-line--mobile" data-hero-line="4">
          <span class="hero-title-line-inner">миров</span>
        </span>
      </h1>
      <p class="lead" data-hero-item="lead">Я создаю сайты, сервисы и визуальные системы для современных брендов — от строгих минималистичных интерфейсов до масштабных имиджевых проектов.</p>
      <div class="hero-actions" data-hero-item="actions">
        <a class="button button-primary" href="#work" data-magnetic>Смотреть работы</a>
        <a class="button button-secondary" href="#contact">Обсудить проект</a>
      </div>
      <p class="hero-origin" data-hero-item="origin">
        <span class="hero-origin-symbol" aria-hidden="true">Æ</span>
        / Северная Осетия
      </p>
    </div>

    <div class="visual-wrap hero-visual-wrap">
      <HeroVisual />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: clip;
    min-height: min(820px, calc(100svh - var(--header-height)));
    padding-block: clamp(2.5rem, 4vw, 4.5rem);
  }

  .hero-container {
    width: min(100% - (var(--page-gutter) * 2), 90rem);
    margin-inline: auto;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: center;
    gap: clamp(2rem, 4vw, 4.5rem);
    min-height: inherit;
  }

  .hero-content {
    min-width: 0;
  }

  .hero h1,
  .hero-title-line,
  .hero-title-line-inner {
    overflow-wrap: normal;
    word-break: normal;
    hyphens: none;
  }

  .hero h1 {
    width: min(100%, 39rem);
    max-width: none;
    margin-bottom: 0;
    overflow: visible;
    font-size: clamp(2.55rem, 11vw, 3.4rem);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: -0.035em;
  }

  .hero-title-line {
    display: block;
    width: max-content;
    max-width: 100%;
    overflow: hidden;
  }

  .hero-title-line-inner {
    display: block;
    overflow-wrap: normal;
    word-break: normal;
    hyphens: none;
  }

  .hero-title-line--mobile {
    display: none;
  }

  .eyebrow {
    margin-bottom: 1.25rem;
    font-size: 0.625rem;
    letter-spacing: 0.17em;
  }

  .lead {
    max-width: 33rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    font-size: clamp(0.95rem, 0.3vw + 0.9rem, 1.075rem);
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    align-items: stretch;
    flex-direction: column;
    gap: 0.5rem;
  }

  .hero-actions :global(.button) {
    min-height: 2.5rem;
    padding: 0.5rem 0.9rem;
    font-size: 0.72rem;
    font-weight: 600;
    border-radius: 0.45rem;
  }

  .hero-origin {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    margin-top: 1.4rem;
    color: var(--color-text-subtle);
    font-size: 0.6875rem;
    line-height: 1.45;
  }

  .hero-origin-symbol {
    color: var(--color-accent);
    font-family: var(--font-display);
    font-size: 0.875rem;
    line-height: 1;
  }

  .visual-wrap {
    position: relative;
    width: 100%;
    min-width: 0;
  }

  @media (min-width: 48rem) {
    .hero-inner {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      gap: clamp(2rem, 3vw, 4rem);
    }

    .hero h1 {
      font-size: clamp(3rem, 5.5vw, 4rem);
    }

    .hero-title-line-inner {
      white-space: nowrap;
    }

    .hero-actions {
      align-items: center;
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  @media (min-width: 68.75rem) {
    .hero-inner {
      grid-template-columns: minmax(35rem, 0.95fr) minmax(34rem, 1.05fr);
      gap: clamp(2rem, 3vw, 4rem);
    }

    .hero h1 {
      font-size: clamp(3.6rem, 4.5vw, 4.75rem);
    }
  }

  @media (max-width: 47.99rem) {
    .hero-title-line--desktop {
      display: none;
    }

    .hero-title-line--mobile {
      display: block;
    }

    .visual-wrap {
      order: 5;
    }

    .hero-origin {
      order: 4;
    }
  }

  @media (max-width: 22.5rem) {
    .hero-title-line {
      width: 100%;
    }

    .hero-title-line-inner {
      white-space: normal;
    }
  }
</style>
