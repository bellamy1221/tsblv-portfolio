---
import BrandMark from './BrandMark.astro';
---

<section class="hero" id="top" aria-labelledby="hero-title" data-hero-viewport>
  <div class="hero-stage" data-hero-scene data-sequence>
    <span class="hero-wordmark" aria-hidden="true">TSBLV</span>
    <span class="hero-light" aria-hidden="true"></span>

    <div class="hero-lens-wrap" data-hero-lens aria-hidden="true">
      <span class="lens-wordmark">TSBLV</span>
      <span class="lens-spectrum"></span>
      <span class="lens-highlight" data-lens-highlight></span>
    </div>

    <div class="site-container content-grid hero-content">
      <div class="hero-copy" data-motion="clip">
        <BrandMark variant="full" size="small" href={null} />
        <p class="kicker">Сайты и автоматизация без лишней сложности</p>
        <h1 id="hero-title">Делаю сайты, которые помогают выглядеть профессионально и получать больше обращений.</h1>
        <p class="hero-lead">Работаю со специалистами, самозанятыми и небольшими командами. Собираю сайты, подключаю CRM, автоматизирую рутину и настраиваю аналитику.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="#work">Посмотреть проекты</a>
          <a class="button button-secondary" href="#contact">Обсудить задачу</a>
        </div>
      </div>
    </div>
  </div>

  <nav class="site-container hero-services" aria-label="Направления работы" data-motion="line">
    <a href="#service-sites" data-service-link="service-sites"><span>01</span>Сайты</a>
    <a href="#service-crm" data-service-link="service-crm"><span>02</span>CRM</a>
    <a href="#service-automation" data-service-link="service-automation"><span>03</span>Автоматизация</a>
    <a href="#service-analytics" data-service-link="service-analytics"><span>04</span>Аналитика</a>
  </nav>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 0.4rem;
  }

  .hero-stage {
    --lens-x: 0px;
    --lens-y: 0px;
    --lens-rx: 0deg;
    --lens-ry: 0deg;
    --lens-scale: 1;
    --light-x: 58%;
    --light-y: 34%;
    position: relative;
    min-height: clamp(43rem, 96svh, 62rem);
    overflow: hidden;
    isolation: isolate;
    border-bottom: 1px solid var(--line);
    background:
      linear-gradient(108deg, transparent 0 62%, rgba(228, 185, 31, 0.08) 72%, transparent 82%),
      linear-gradient(24deg, rgba(181, 31, 43, 0.1), transparent 30%),
      var(--page);
  }

  .hero-stage::before {
    position: absolute;
    z-index: -2;
    inset: -18%;
    background:
      conic-gradient(from 218deg at 62% 44%, transparent 0 25%, rgba(181, 31, 43, 0.2) 31%, rgba(247, 245, 239, 0.46) 37%, rgba(228, 185, 31, 0.2) 43%, transparent 51% 100%);
    content: '';
    opacity: 0.82;
    transform: rotate(-4deg);
  }

  :global(html[data-theme='dark']) .hero-stage {
    background:
      linear-gradient(108deg, transparent 0 62%, rgba(228, 185, 31, 0.05) 72%, transparent 82%),
      linear-gradient(24deg, rgba(181, 31, 43, 0.07), transparent 30%),
      var(--page);
  }

  :global(html[data-theme='dark']) .hero-stage::before {
    opacity: 0.46;
  }

  .hero-wordmark,
  .lens-wordmark {
    font-size: clamp(10rem, 25vw, 24rem);
    font-weight: 790;
    line-height: 0.67;
    letter-spacing: -0.085em;
    white-space: nowrap;
  }

  .hero-wordmark {
    position: absolute;
    z-index: -1;
    top: 48%;
    left: 50%;
    color: color-mix(in srgb, var(--text) 27%, transparent);
    text-shadow:
      0 -1px rgba(255, 255, 255, 0.62),
      0 2px rgba(17, 19, 23, 0.24),
      0 2rem 4rem rgba(17, 19, 23, 0.13);
    transform: translate(-50%, -50%);
  }

  .hero-light {
    position: absolute;
    z-index: 1;
    inset: 0;
    background:
      radial-gradient(ellipse 28% 40% at var(--light-x) var(--light-y), rgba(255, 255, 255, 0.32), transparent 68%),
      linear-gradient(106deg, transparent 30%, rgba(181, 31, 43, 0.09) 43%, rgba(255, 255, 255, 0.28) 49%, rgba(228, 185, 31, 0.11) 55%, transparent 64%);
    background-position: 0 0, 140% 0;
    background-size: 100% 100%, 230% 100%;
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .hero-stage.is-sequence-visible .hero-light {
    animation: hero-sweep 2s 300ms var(--ease-out) both;
  }

  .hero-lens-wrap {
    position: absolute;
    z-index: 3;
    top: 48%;
    left: 50%;
    width: clamp(11rem, 19vw, 18rem);
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.66);
    border-radius: 50%;
    box-shadow:
      0 2rem 5rem rgba(17, 19, 23, 0.22),
      inset 1rem 1rem 2rem rgba(255, 255, 255, 0.14),
      inset -1rem -1rem 2rem rgba(17, 19, 23, 0.16);
    backdrop-filter: blur(2px) brightness(1.12) contrast(1.12);
    pointer-events: none;
    transform: translate(calc(-50% + var(--lens-x)), calc(-50% + var(--lens-y))) rotateX(var(--lens-rx)) rotateY(var(--lens-ry)) scale(var(--lens-scale));
    transform-style: preserve-3d;
    transition: transform 520ms var(--ease-out), box-shadow 420ms var(--ease-out);
  }

  .lens-wordmark {
    position: absolute;
    top: 50%;
    left: 50%;
    color: color-mix(in srgb, var(--text) 58%, transparent);
    text-shadow:
      -1px 0 rgba(181, 31, 43, 0.38),
      1px 0 rgba(228, 185, 31, 0.36),
      0 -1px rgba(255, 255, 255, 0.7);
    transform: translate(calc(-50% - var(--lens-x)), calc(-50% - var(--lens-y))) scale(1.065, 1.04);
    transition: transform 520ms var(--ease-out);
  }

  .lens-spectrum,
  .lens-highlight {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
  }

  .lens-spectrum {
    border: 1px solid rgba(255, 255, 255, 0.34);
    background: conic-gradient(from 142deg, rgba(181, 31, 43, 0.2), transparent 22%, rgba(228, 185, 31, 0.2) 42%, transparent 65%, rgba(255, 255, 255, 0.18));
    mix-blend-mode: screen;
  }

  .lens-highlight {
    --highlight-x: 38%;
    --highlight-y: 28%;
    background: radial-gradient(circle at var(--highlight-x) var(--highlight-y), rgba(255, 255, 255, 0.72), transparent 18%);
    opacity: 0.54;
  }

  .hero-content {
    min-height: inherit;
    align-items: end;
    padding-top: 7rem;
    padding-bottom: clamp(3rem, 6vh, 5rem);
  }

  .hero-copy {
    position: relative;
    z-index: 5;
    grid-column: 1 / span 6;
    max-width: 44rem;
  }

  .hero-copy :global(.brand-mark) {
    --brand-color: var(--text);
    --brand-muted: var(--text-muted);
    --brand-line: var(--line-strong);
    margin-bottom: clamp(3rem, 10vh, 7rem);
  }

  .kicker {
    margin: 0 0 0.8rem;
    color: var(--red);
    font-size: 0.67rem;
    font-weight: 760;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.25rem, 4vw, 4.8rem);
    font-weight: 540;
    line-height: 0.98;
    letter-spacing: -0.067em;
    text-wrap: balance;
  }

  .hero-lead {
    max-width: 39rem;
    margin: 1.2rem 0 0;
    color: var(--text-muted);
    font-size: clamp(0.95rem, 1.25vw, 1.12rem);
    line-height: 1.58;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.45rem;
  }

  .hero-services {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--line);
  }

  .hero-services a {
    display: flex;
    min-height: 4.4rem;
    align-items: center;
    gap: 0.8rem;
    border-right: 1px solid var(--line);
    color: var(--text);
    font-size: clamp(0.78rem, 1.2vw, 1rem);
    font-weight: 670;
    text-decoration: none;
    transition: color 280ms ease, padding-left 360ms var(--ease-out);
  }

  .hero-services a:last-child {
    border-right: 0;
  }

  .hero-services a:hover,
  .hero-services a:focus-visible {
    padding-left: 0.45rem;
    color: var(--red);
  }

  .hero-services span {
    color: var(--text-muted);
    font-size: 0.6rem;
  }

  @keyframes hero-sweep {
    to { background-position: 0 0, -25% 0; }
  }

  @media (max-width: 63.99rem) {
    .hero-copy {
      grid-column: 1 / span 8;
    }

    .hero-wordmark,
    .lens-wordmark {
      font-size: clamp(9rem, 28vw, 17rem);
    }
  }

  @media (hover: none) {
    .hero-lens-wrap {
      animation: touch-lens 7s ease-in-out infinite alternate;
    }
  }

  @keyframes touch-lens {
    to { transform: translate(calc(-50% + 1.4rem), calc(-50% - 0.75rem)); }
  }

  @media (max-width: 47.99rem) {
    .hero-stage {
      min-height: 44rem;
    }

    .hero-content {
      display: flex;
      align-items: flex-end;
      padding-top: 5.5rem;
      padding-bottom: 2.25rem;
    }

    .hero-copy :global(.brand-mark) {
      margin-bottom: 14rem;
    }

    .hero-wordmark,
    .lens-wordmark {
      top: 38%;
      font-size: clamp(7.4rem, 38vw, 11rem);
    }

    .lens-wordmark { top: 50%; }

    .hero-lens-wrap {
      top: 38%;
      width: clamp(8rem, 34vw, 10rem);
    }

    h1 {
      font-size: clamp(2.05rem, 10.2vw, 3.3rem);
    }

    .hero-services {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-services a {
      min-height: 3.8rem;
      border-bottom: 1px solid var(--line);
    }

    .hero-services a:nth-child(2) {
      border-right: 0;
    }
  }
</style>
