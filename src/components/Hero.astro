---
import BrandMark from './BrandMark.astro';
---

<section class="hero" id="top" aria-labelledby="hero-title">
  <div class="site-container content-grid hero-grid">
    <div class="hero-copy" data-motion="clip">
      <p class="kicker">Сайты и автоматизация без лишней сложности</p>
      <h1 id="hero-title">Делаю сайты, которые помогают выглядеть профессионально и получать больше обращений.</h1>
      <p class="hero-lead">Работаю со специалистами, самозанятыми и небольшими командами. Могу собрать сайт с нуля, подключить CRM, автоматизировать рутину и настроить аналитику.</p>
      <div class="hero-actions">
        <a class="button button-primary" href="#work">Посмотреть проекты</a>
        <a class="button button-secondary" href="#contact">Обсудить задачу</a>
      </div>
    </div>

    <div class="hero-visual-entry" data-motion="scale-depth">
      <div class="hero-scene tech-frame" data-hero-viewport data-hero-scene>
        <span class="scene-index" aria-hidden="true">TS / REFRACTION 01</span>
        <span class="hero-wordmark" aria-hidden="true">TSBLV</span>

        <div class="orbit orbit--wide" data-orbit-depth="1" aria-hidden="true"></div>
        <div class="orbit orbit--tight" data-orbit-depth="2" aria-hidden="true"></div>

        <div class="lens-position">
          <div class="hero-lens" data-hero-lens aria-hidden="true">
            <span class="lens-highlight" data-lens-highlight></span>
            <span class="lens-rim"></span>
          </div>
        </div>

        <a class="service-chip chip-site" href="#service-sites" data-service-chip="service-sites"><i></i>Сайты</a>
        <a class="service-chip chip-crm" href="#service-crm" data-service-chip="service-crm"><i></i>CRM</a>
        <a class="service-chip chip-auto" href="#service-automation" data-service-chip="service-automation"><i></i>Автоматизация</a>
        <a class="service-chip chip-data" href="#service-analytics" data-service-chip="service-analytics"><i></i>Аналитика</a>

        <p class="object-note">Выберите направление</p>
      </div>
    </div>

    <div class="hero-brand" data-motion="fade-blur">
      <BrandMark variant="full" size="medium" href={null} />
      <p>Работаю напрямую<br />и остаюсь на связи после запуска</p>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: clamp(5.5rem, 7vw, 7rem) 0 clamp(4rem, 6vw, 6rem);
  }

  .hero-grid {
    align-items: center;
    row-gap: clamp(2rem, 4vw, 3.5rem);
  }

  .hero-copy {
    z-index: 2;
    grid-column: 1 / span 6;
  }

  .kicker {
    margin: 0 0 1rem;
    color: var(--flag-red);
    font-size: 0.7rem;
    font-weight: 760;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1 {
    max-width: 48rem;
    margin: 0;
    font-size: clamp(2.7rem, 5.7vw, 5.65rem);
    font-weight: 560;
    line-height: 0.96;
    letter-spacing: -0.07em;
    text-wrap: balance;
  }

  .hero-lead {
    max-width: 39rem;
    margin: 1.45rem 0 0;
    color: var(--text-muted);
    font-size: clamp(1rem, 1.35vw, 1.16rem);
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.65rem;
  }

  .hero-visual-entry {
    grid-column: 7 / -1;
  }

  .hero-scene {
    --scene-x: 0px;
    --scene-y: 0px;
    position: relative;
    min-height: clamp(23rem, 38vw, 32rem);
    overflow: hidden;
    isolation: isolate;
    border: 1px solid var(--line-strong);
    border-radius: 1.35rem;
    background:
      conic-gradient(from 222deg at 66% 46%, transparent 0 23%, rgba(240, 201, 40, 0.11) 30%, rgba(255, 255, 255, 0.18) 35%, rgba(220, 52, 65, 0.08) 41%, transparent 50% 100%),
      linear-gradient(138deg, rgba(255, 255, 255, 0.33), rgba(16, 18, 22, 0.09) 48%, rgba(255, 255, 255, 0.12));
    box-shadow: var(--shadow-lg), inset 0 1px 0 rgba(255, 255, 255, 0.62);
    backdrop-filter: blur(16px) saturate(115%);
  }

  html[data-theme='dark'] .hero-scene {
    background:
      conic-gradient(from 222deg at 66% 46%, transparent 0 23%, rgba(240, 201, 40, 0.08) 30%, rgba(220, 229, 235, 0.1) 35%, rgba(220, 52, 65, 0.07) 41%, transparent 50% 100%),
      linear-gradient(138deg, rgba(255, 255, 255, 0.07), rgba(16, 18, 22, 0.16) 48%, rgba(255, 255, 255, 0.04));
  }

  .hero-scene::before {
    position: absolute;
    inset: 0;
    background: linear-gradient(108deg, transparent 30%, rgba(255, 255, 255, 0.3) 48%, transparent 65%);
    background-position: 130% 0;
    background-size: 220% 100%;
    content: '';
    pointer-events: none;
  }

  .hero-visual-entry.is-motion-visible .hero-scene::before {
    animation: scene-sheen 1.8s 350ms var(--ease-out) both;
  }

  .scene-index {
    position: absolute;
    top: 1.15rem;
    right: 1.25rem;
    color: color-mix(in srgb, var(--text) 52%, transparent);
    font-size: 0.54rem;
    font-weight: 720;
    letter-spacing: 0.12em;
  }

  .hero-wordmark {
    position: absolute;
    z-index: -1;
    top: 50%;
    left: 50%;
    color: color-mix(in srgb, var(--text) 44%, transparent);
    font-size: clamp(6rem, 17vw, 15rem);
    font-weight: 780;
    line-height: 0.6;
    letter-spacing: -0.075em;
    text-shadow: 0 -1px rgba(255, 255, 255, 0.55), 0 1.5rem 3rem rgba(16, 18, 22, 0.16);
    transform: translate(calc(-50% + var(--scene-x)), calc(-50% + var(--scene-y)));
    transition: transform 520ms var(--ease-out);
    white-space: nowrap;
  }

  .lens-position {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(10.5rem, 20vw, 17rem);
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    perspective: 700px;
  }

  .hero-lens {
    --lens-rotate-x: 0deg;
    --lens-rotate-y: 0deg;
    --lens-scale: 1;
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.68);
    border-radius: 50%;
    background:
      radial-gradient(circle at 34% 28%, rgba(255, 255, 255, 0.42), transparent 26%),
      conic-gradient(from 145deg, rgba(220, 52, 65, 0.16), rgba(255, 255, 255, 0.07) 22%, rgba(240, 201, 40, 0.2) 39%, rgba(255, 255, 255, 0.12) 58%, rgba(220, 52, 65, 0.09) 76%, rgba(255, 255, 255, 0.18));
    box-shadow:
      0 2rem 5rem rgba(16, 18, 22, 0.24),
      inset 1rem 1rem 2rem rgba(255, 255, 255, 0.17),
      inset -1rem -1rem 2rem rgba(16, 18, 22, 0.14);
    backdrop-filter: blur(2px) brightness(1.08) contrast(1.05);
    transform: rotateX(var(--lens-rotate-x)) rotateY(var(--lens-rotate-y)) scale(var(--lens-scale));
    transition: transform 480ms var(--ease-out), box-shadow 420ms var(--ease-out);
    transform-style: preserve-3d;
  }

  .lens-highlight {
    --highlight-x: 35%;
    --highlight-y: 28%;
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at var(--highlight-x) var(--highlight-y), rgba(255, 255, 255, 0.72), transparent 17%);
    opacity: 0.66;
    transition: background-position 300ms var(--ease-out);
  }

  .lens-rim {
    position: absolute;
    inset: 7%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: inherit;
    box-shadow: inset 0 0 1.2rem rgba(255, 255, 255, 0.12);
  }

  .orbit {
    --orbit-x: 0px;
    --orbit-y: 0px;
    position: absolute;
    z-index: -1;
    border: 1px solid color-mix(in srgb, var(--ice) 36%, transparent);
    border-radius: 50%;
    transform: translate(var(--orbit-x), var(--orbit-y));
    transition: transform 620ms var(--ease-out);
  }

  .orbit--wide {
    top: 5%;
    right: 7%;
    width: 53%;
    aspect-ratio: 1;
  }

  .orbit--tight {
    bottom: -20%;
    left: 20%;
    width: 62%;
    aspect-ratio: 1;
    border-color: color-mix(in srgb, var(--flag-yellow) 24%, transparent);
  }

  .service-chip {
    --chip-x: 0px;
    --chip-y: 0px;
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.62rem 0.85rem;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    background: var(--surface-glass-strong);
    box-shadow: 0 0.75rem 1.8rem rgba(16, 18, 22, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(14px);
    color: var(--text);
    font: 650 clamp(0.65rem, 1vw, 0.82rem) / 1 var(--font-sans);
    text-decoration: none;
    transform: translate(var(--chip-x), var(--chip-y));
    transition: transform 420ms var(--ease-out), background-color 320ms var(--ease-out), border-color 320ms var(--ease-out);
  }

  .service-chip i {
    width: 0.43rem;
    height: 0.43rem;
    border-radius: 50%;
    background: var(--flag-red);
    box-shadow: 0 0 0 0.18rem rgba(220, 52, 65, 0.12);
  }

  .service-chip:hover,
  .service-chip:focus-visible,
  .service-chip.is-active {
    border-color: var(--flag-yellow);
    background: var(--surface-glass-strong);
  }

  .chip-site { top: 14%; left: 10%; }
  .chip-crm { top: 19%; right: 10%; }
  .chip-auto { bottom: 15%; left: 14%; }
  .chip-data { right: 14%; bottom: 12%; }
  .chip-crm i, .chip-data i { background: var(--flag-yellow); box-shadow: 0 0 0 0.18rem rgba(240, 201, 40, 0.12); }

  .object-note {
    position: absolute;
    right: 1.2rem;
    bottom: 1rem;
    margin: 0;
    color: color-mix(in srgb, var(--text) 58%, transparent);
    font-size: 0.56rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-brand {
    display: flex;
    grid-column: 1 / -1;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--line);
  }

  .hero-brand p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.72rem;
    line-height: 1.6;
    text-align: right;
  }

  @keyframes scene-sheen {
    to { background-position: -25% 0; }
  }

  @media (max-width: 63.99rem) {
    .hero-copy,
    .hero-visual-entry {
      grid-column: 1 / -1;
    }

    .hero-copy {
      max-width: 56rem;
    }
  }

  @media (max-width: 35rem) {
    .hero {
      padding-top: 5rem;
    }

    .hero-scene {
      min-height: 22rem;
      margin-inline: calc(var(--gutter) * -0.5);
    }

    .chip-site { left: 5%; }
    .chip-crm { right: 5%; }
    .chip-auto { bottom: 12%; left: 6%; }
    .chip-data { right: 6%; bottom: 9%; }
    .object-note { display: none; }

    .hero-brand {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero-brand p { text-align: left; }
  }
</style>
