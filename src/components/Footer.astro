---
import BrandMark from './BrandMark.astro';
import { siteConfig } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="footer" data-sequence>
  <div class="site-container footer-wordmark-stage" data-motion="scale-depth" data-footer-light>
    <span class="footer-wordmark" aria-hidden="true">TSBLV</span>
    <span class="footer-wordmark-light" aria-hidden="true">TSBLV</span>
  </div>

  <div class="site-container content-grid footer-contact" data-motion="fade-blur">
    <div class="footer-brand">
      <BrandMark variant="full" size="medium" href="#top" ariaLabel="TSBLV — в начало страницы" />
    </div>
    <nav aria-label="Контакты">
      <a href={siteConfig.telegramUrl} target="_blank" rel="noreferrer">Telegram</a>
      <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
    </nav>
  </div>

  <div class="site-container footer-bottom" data-motion="line-draw">
    <span>© {year} TSBLV</span>
    <span>Без трекеров и лишних cookies</span>
  </div>
</footer>

<style>
  .footer {
    z-index: 0;
    overflow: hidden;
    padding: clamp(1.5rem, 3vw, 3.25rem) 0 1.5rem;
    color: var(--white);
  }

  .footer::before {
    position: absolute;
    z-index: -1;
    inset: -10rem 0 0;
    background:
      conic-gradient(from 225deg at 76% 36%, transparent 0 28%, rgba(240, 201, 40, 0.13) 34%, rgba(255, 255, 255, 0.1) 39%, rgba(181, 31, 43, 0.11) 44%, transparent 52% 100%),
      linear-gradient(to bottom, rgba(16, 18, 22, 0.94), var(--surface-deep));
    content: '';
    pointer-events: none;
    transition: background 560ms var(--ease-out), opacity 560ms var(--ease-out);
  }

  .footer-wordmark-stage {
    --footer-light-x: 50%;
    --footer-light-y: 50%;
    position: relative;
    height: clamp(7rem, 14.5vw, 13rem);
    overflow: hidden;
    border-bottom: 1px solid var(--line-on-dark);
  }

  .footer-wordmark,
  .footer-wordmark-light {
    position: absolute;
    top: 50%;
    left: 50%;
    font-size: clamp(6rem, 18.5vw, 17rem);
    font-weight: 780;
    line-height: 0.72;
    letter-spacing: -0.065em;
    transform: translate(-50%, -38%);
    white-space: nowrap;
  }

  .footer-wordmark {
    color: rgba(6, 8, 11, 0.56);
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.06);
    text-shadow:
      0 -1px 0 rgba(255, 255, 255, 0.13),
      0 2px 0 rgba(0, 0, 0, 0.82),
      0 0.16rem 0 rgba(255, 255, 255, 0.025),
      0 1.2rem 2.8rem rgba(0, 0, 0, 0.42);
  }

  .footer-wordmark-light {
    background:
      radial-gradient(circle at var(--footer-light-x) var(--footer-light-y), rgba(255, 255, 255, 0.22), rgba(255, 252, 235, 0.09) 9%, transparent 25%),
      linear-gradient(104deg, transparent 28%, rgba(181, 31, 43, 0.1) 38%, rgba(255, 255, 255, 0.2) 45%, rgba(240, 201, 40, 0.11) 51%, transparent 63%);
    background-position: 0 0, 120% 0;
    background-size: 100% 100%, 230% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .footer.is-sequence-visible .footer-wordmark-light {
    animation: footer-light 2.4s 500ms var(--ease-out) both;
  }

  .footer-contact {
    align-items: start;
    padding-block: 1.75rem;
  }

  .footer-brand {
    grid-column: 1 / span 6;
  }

  .footer :global(.brand-mark) {
    --brand-color: var(--white);
    --brand-muted: rgba(243, 245, 247, 0.56);
    --brand-line: rgba(243, 245, 247, 0.22);
    --brand-accent: var(--flag-red);
  }

  .footer nav {
    display: grid;
    grid-column: 10 / -1;
    justify-items: end;
    gap: 0.75rem;
  }

  .footer nav a {
    color: rgba(243, 245, 247, 0.74);
    font-size: 0.82rem;
    text-decoration: none;
    transition: color 320ms var(--ease-out), transform 320ms var(--ease-out);
  }

  .footer nav a:hover {
    color: var(--flag-yellow);
    transform: translateX(-0.2rem);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--line-on-dark);
    color: rgba(243, 245, 247, 0.5);
    font-size: 0.62rem;
  }

  @keyframes footer-light {
    to { background-position: 0 0, -25% 0; }
  }

  @media (max-width: 47.99rem) {
    .footer-wordmark-stage {
      width: 100%;
      height: clamp(6rem, 28vw, 9rem);
    }

    .footer-wordmark,
    .footer-wordmark-light {
      font-size: clamp(5.5rem, 28vw, 9rem);
      letter-spacing: -0.055em;
    }

    .footer-brand,
    .footer nav {
      grid-column: 1 / -1;
    }

    .footer nav {
      justify-items: start;
      margin-top: 1.5rem;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
