---
import BrandMark from './BrandMark.astro';
import { siteConfig } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="site-container footer-main">
    <BrandMark variant="full" size="medium" href="#top" ariaLabel="TSBLV — в начало страницы" />
    <nav aria-label="Контакты"><a href={siteConfig.telegramUrl} target="_blank" rel="noreferrer">Telegram</a><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></nav>
  </div>
  <div class="footer-wordmark" aria-hidden="true">TSBLV</div>
  <div class="site-container footer-bottom"><span>© {year} TSBLV</span><span>Без трекеров и лишних cookies</span></div>
</footer>

<style>
  .footer { position:relative; overflow:hidden; padding:3rem 0 1.5rem; background:linear-gradient(145deg,rgba(7,21,34,.9),rgba(19,27,37,.82)); color:var(--on-inverse); }.footer::before { position:absolute; inset:0; background:radial-gradient(ellipse at 78% 0%,color-mix(in srgb,var(--cyan) 32%,transparent),transparent 42%),linear-gradient(90deg,transparent,color-mix(in srgb,var(--signal-yellow) 9%,transparent),transparent); content:''; pointer-events:none; }.footer-main,.footer-bottom { position:relative; z-index:1; }.footer-main { display:flex; align-items:flex-start; justify-content:space-between; gap:2rem; padding-bottom:1.4rem; }.footer :global(.brand-mark) { --ink:var(--on-inverse); --muted:rgba(242,248,252,.6); --line-strong:rgba(255,255,255,.28); }.footer nav { display:grid; justify-items:end; gap:.75rem; }.footer nav a { color:rgba(240,247,252,.78); font-size:.82rem; text-decoration:none; transition:color .2s ease,transform .2s ease; }.footer nav a:hover { color:var(--cyan); transform:translateX(-.2rem); }.footer-wordmark { position:relative; z-index:0; width:100%; margin:-.08em 0 -.18em; color:rgba(245,250,255,.08); font-size:clamp(5rem,19vw,18rem); font-weight:780; letter-spacing:-.12em; line-height:.72; text-align:center; text-shadow:0 -1px rgba(255,255,255,.18),0 .65rem 2.5rem rgba(20,120,255,.26); white-space:nowrap; }.footer-wordmark::after { position:absolute; inset:0; background:linear-gradient(100deg,transparent 30%,rgba(255,255,255,.32) 47%,transparent 63%); background-size:220% 100%; background-position:120% 0; -webkit-background-clip:text; color:transparent; content:'TSBLV'; animation:footer-sheen 12s ease-in-out infinite; }.footer-bottom { display:flex; justify-content:space-between; gap:1rem; padding-top:1.25rem; border-top:1px solid rgba(255,255,255,.15); color:rgba(233,243,249,.56); font-size:.62rem; }@keyframes footer-sheen { 50% { background-position:-20% 0; } }@media(max-width:35rem) { .footer-main,.footer-bottom { flex-direction:column; }.footer nav { justify-items:start; } }
</style>
