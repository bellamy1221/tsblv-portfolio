---
import BrandMark from './BrandMark.astro';

const navigation = [
  { label: 'Работы', href: '/work/' },
  { label: 'Обо мне', href: '/#about' },
  { label: 'Услуги', href: '/#services' },
  { label: 'Контакты', href: '/#contact' },
];
---

<footer id="footer" data-reveal="up">
  <div class="container footer-inner">
    <div class="footer-brand">
      <BrandMark variant="full" size="medium" orientation="horizontal" href="#top" />
      <p class="footer-name">Джордж Цаболов</p>
      <p class="footer-origin">Северная Осетия</p>
    </div>

    <nav aria-label="Навигация в подвале">
      <ul class="list-reset">
        {navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer-contact">
      <a href="mailto:hello@tsblv.com">hello@tsblv.com</a>
      <p>© {new Date().getFullYear()}</p>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-line);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2.5rem;
    padding-block: clamp(3rem, 7vw, 4.5rem);
  }

  .footer-brand {
    min-width: 0;
  }

  .footer-name {
    margin-top: 1rem;
    color: var(--color-text-muted);
    font-size: var(--font-size-ui);
  }

  .footer-origin {
    margin-top: 0.35rem;
    color: var(--color-text-subtle);
    font-size: var(--font-size-meta);
  }

  nav ul {
    display: grid;
    gap: 0.55rem;
  }

  nav a,
  .footer-contact a {
    color: var(--color-text-muted);
    font-size: var(--font-size-ui);
    text-decoration-color: transparent;
    transition: color var(--duration-fast), text-decoration-color var(--duration-fast);
  }

  nav a:hover,
  nav a:focus-visible,
  .footer-contact a:hover,
  .footer-contact a:focus-visible {
    color: var(--color-text);
    text-decoration-color: var(--color-accent-soft);
  }

  .footer-contact {
    display: grid;
    align-content: start;
    gap: 0.45rem;
  }

  .footer-contact p {
    color: var(--color-text-subtle);
    font-size: var(--font-size-meta);
  }

  @media (min-width: 48rem) {
    .footer-inner {
      grid-template-columns: 1fr auto 1fr;
      align-items: start;
    }

    .footer-contact {
      justify-items: end;
      text-align: right;
    }
  }
</style>
