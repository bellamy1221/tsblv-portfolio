---
import BrandMark from './BrandMark.astro';
import { siteConfig } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="site-container footer-main">
    <BrandMark variant="full" size="medium" href="#top" ariaLabel="TSBLV — в начало страницы" />
    <nav aria-label="Контакты">
      <a href={siteConfig.telegramUrl} target="_blank" rel="noreferrer">Telegram</a>
      <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
    </nav>
  </div>
  <div class="site-container footer-bottom">
    <span>© {year} TSBLV</span>
    <span>Без трекеров и лишних cookies</span>
  </div>
</footer>

<style>
  .footer { padding: 3rem 0 1.5rem; background: var(--surface-inverse); color: var(--on-inverse); }
  .footer-main { display: flex; align-items: flex-start; justify-content: space-between; gap: 2rem; padding-bottom: 3rem; }
  .footer :global(.brand-mark) { --ink: var(--on-inverse); --muted: #92958e; --line-strong: #42443f; }
  nav { display: grid; justify-items: end; gap: .75rem; }
  nav a { color: #c6c8c2; font-size: .82rem; text-decoration: none; }
  nav a:hover { color: white; }
  .footer-bottom { display: flex; justify-content: space-between; gap: 1rem; padding-top: 1.25rem; border-top: 1px solid #343632; color: #858881; font-size: .62rem; }
  @media (max-width: 35rem) { .footer-main { flex-direction: column; } nav { justify-items: start; } .footer-bottom { flex-direction: column; } }
</style>
