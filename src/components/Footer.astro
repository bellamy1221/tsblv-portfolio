---
import BrandMark from './BrandMark.astro';
import { siteConfig } from '../config/site';

const year = new Date().getFullYear();
---

<footer class="footer" data-sequence>
  <div class="footer-wordmark-stage" data-motion="scene" data-footer-light>
    <span class="footer-wordmark" aria-hidden="true">TSBLV</span>
    <span class="footer-wordmark-light" aria-hidden="true">TSBLV</span>
  </div>

  <div class="site-container content-grid footer-contact" data-motion="text">
    <div class="footer-brand">
      <BrandMark variant="full" size="medium" href="#top" ariaLabel="TSBLV — в начало страницы" />
    </div>
    <nav aria-label="Контакты">
      <a href={siteConfig.telegramUrl} target="_blank" rel="noreferrer">Telegram</a>
      <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
    </nav>
  </div>

  <div class="site-container footer-bottom" data-motion="line">
    <span>© {year} TSBLV</span>
    <span>Без трекеров и лишних cookies</span>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    padding: 0 0 1.4rem;
    color: var(--white);
    background: var(--dark);
  }

  .footer-wordmark-stage {
    --footer-light-x: 50%;
    --footer-light-y: 50%;
    position: relative;
    height: clamp(10rem, 24vw, 23rem);
    overflow: hidden;
    border-bottom: 1px solid var(--line-dark);
  }

  .footer-wordmark,
  .footer-wordmark-light {
    position: absolute;
    top: 50%;
    left: 50%;
    font-size: clamp(9rem, 26vw, 25rem);
    font-weight: 790;
    line-height: 0.66;
    letter-spacing: -0.086em;
    transform: translate(-50%, -40%);
    white-space: nowrap;
  }

  .footer-wordmark {
    color: #0d0f12;
    -webkit-text-stroke: 1px rgba(247, 245, 239, 0.07);
    text-shadow:
      0 -1px rgba(247, 245, 239, 0.12),
      0 3px rgba(0, 0, 0, 0.75),
      0 2rem 4rem rgba(0, 0, 0, 0.46);
  }

  .footer-wordmark-light {
    background:
      radial-gradient(circle at var(--footer-light-x) var(--footer-light-y), rgba(247, 245, 239, 0.24), rgba(247, 245, 239, 0.07) 10%, transparent 26%),
      linear-gradient(105deg, transparent 29%, rgba(181, 31, 43, 0.13) 38%, rgba(247, 245, 239, 0.22) 46%, rgba(228, 185, 31, 0.13) 52%, transparent 64%);
    background-position: 0 0, 125% 0;
    background-size: 100% 100%, 230% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .footer.is-sequence-visible .footer-wordmark-light {
    animation: footer-sweep 2.4s 350ms var(--ease-out) both;
  }

  .footer-contact {
    align-items: start;
    padding-block: clamp(2rem, 4vw, 3.5rem);
  }

  .footer-brand { grid-column: 1 / span 6; }

  .footer :global(.brand-mark) {
    --brand-color: var(--white);
    --brand-muted: rgba(247, 245, 239, 0.52);
    --brand-line: rgba(247, 245, 239, 0.2);
    --brand-accent: var(--red);
  }

  .footer nav {
    display: grid;
    grid-column: 9 / -1;
    justify-items: end;
    gap: 0.75rem;
  }

  .footer nav a {
    position: relative;
    color: rgba(247, 245, 239, 0.72);
    font-size: 0.82rem;
    text-decoration: none;
    transition: color 280ms ease;
  }

  .footer nav a::after {
    position: absolute;
    right: 0;
    bottom: -0.25rem;
    left: 0;
    height: 1px;
    background: var(--yellow);
    content: '';
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 320ms var(--ease-out);
  }

  .footer nav a:hover,
  .footer nav a:focus-visible { color: var(--white); }
  .footer nav a:hover::after,
  .footer nav a:focus-visible::after { transform: scaleX(1); transform-origin: left; }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.15rem;
    border-top: 1px solid var(--line-dark);
    color: rgba(247, 245, 239, 0.46);
    font-size: 0.61rem;
  }

  @keyframes footer-sweep {
    to { background-position: 0 0, -25% 0; }
  }

  @media (max-width: 47.99rem) {
    .footer-wordmark-stage { height: clamp(7rem, 31vw, 10rem); }
    .footer-wordmark,
    .footer-wordmark-light { font-size: clamp(7rem, 34vw, 11rem); }
    .footer-brand,
    .footer nav { grid-column: 1 / -1; }
    .footer nav { justify-items: start; margin-top: 1.5rem; }
    .footer-bottom { flex-direction: column; }
  }
</style>
