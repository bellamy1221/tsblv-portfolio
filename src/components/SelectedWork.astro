---
import { conceptCases } from '../data/home';
import ProjectPreview from './ProjectPreview.astro';
---

<section class="selected-work" id="work" aria-labelledby="work-title">
  <div class="site-container content-grid work-heading" data-motion="clip">
    <div>
      <p class="section-label">03 / Возможности в действии</p>
      <h2 id="work-title">Откройте,<br />чем может стать идея</h2>
    </div>
    <p>Сначала — один собранный архив возможностей. Ниже — три самостоятельных концепта, которые показывают разные сценарии продукта.</p>
  </div>

  <div class="site-container folder-intro" data-portfolio-folder data-sequence>
    <p>CURIOUS? / OPEN THE ARCHIVE</p>
    <div class="portfolio-folder">
      <span class="portfolio-folder__back" aria-hidden="true"></span>
      <span class="portfolio-folder__papers" aria-hidden="true">
        <i><small>01</small><b>STRATEGY</b></i>
        <i><small>02</small><b>DESIGN</b></i>
        <i><small>03</small><b>BUILD</b></i>
      </span>
      <span class="portfolio-folder__front" aria-hidden="true">
        <small>PORTFOLIO</small>
        <strong>TSBLV</strong>
      </span>
      <button class="portfolio-folder__action" type="button" data-folder-toggle aria-expanded="false" aria-label="Открыть папку портфолио">→</button>
    </div>
    <span>Нажмите, чтобы открыть</span>
  </div>

  <div class="site-container work-browser" data-work-browser>
    <div class="work-index" aria-label="Концепции проектов">
      {conceptCases.map((project, index) => (
        <article class:list={['work-row', index === 0 && 'is-active']} data-work-row={project.id}>
          <button
            type="button"
            data-work-trigger={project.id}
            aria-controls={`work-preview-${project.id}`}
            aria-expanded={index === 0 ? 'true' : 'false'}
          >
            <span>{project.id}</span>
            <span class="work-row__title">{project.title}</span>
            <small>{project.kind}</small>
          </button>
          <div class="work-row__detail">
            <div>
              <p><span>Задача</span>{project.task}</p>
              <p><span>Решение</span>{project.solution}</p>
              <ul aria-label="Услуги">{project.services.map((service) => <li>{service}</li>)}</ul>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="work-preview-stage" aria-live="polite">
      <span class="work-preview-caption">SELECTED CONCEPT / HOVER OR FOCUS</span>
      {conceptCases.map((project, index) => (
        <article
          class:list={['case-preview', 'case-study', index === 0 && 'is-active']}
          id={`work-preview-${project.id}`}
          data-work-file={project.id}
          aria-hidden={index === 0 ? 'false' : 'true'}
          data-sequence
        >
          <div class="case-preview__meta"><span>{project.id} / {project.type}</span><strong>{project.kind}</strong></div>
          <ProjectPreview kind={project.preview} />
        </article>
      ))}
    </div>
  </div>
</section>

<style is:global>
  .selected-work {
    position: relative;
    isolation: isolate;
    overflow: clip;
    padding: clamp(7rem, 9vw, 10rem) 0 clamp(7rem, 9vw, 10rem);
    color: var(--white);
    background: transparent;
  }

  .work-heading { display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(19rem, 0.55fr); align-items: end; gap: clamp(2rem, 6vw, 7rem); margin-bottom: clamp(4rem, 7vw, 7rem); }
  .work-heading > div,
  .work-heading > p { grid-column: auto; min-width: 0; }
  .work-heading > p { max-width: 29rem; margin: 0 0 0.4rem; color: rgba(247, 245, 239, 0.62); font-size: 0.9rem; line-height: 1.65; }
  .work-heading h2 { font-size: clamp(3.1rem, 6.8vw, 7rem); }
  .selected-work .section-label { color: var(--yellow); }

  .folder-intro { display: grid; min-height: clamp(26rem, 40vw, 36rem); place-items: center; align-content: center; gap: 1.2rem; }
  .folder-intro > p { margin: 0; color: rgba(247, 245, 239, 0.42); font-size: 0.52rem; letter-spacing: 0.16em; }
  .folder-intro > span { color: rgba(247, 245, 239, 0.44); font-size: 0.58rem; }

  .portfolio-folder {
    position: relative;
    width: min(42rem, 82vw);
    aspect-ratio: 1.45;
    padding: 0;
    overflow: hidden;
    border: 0;
    border-radius: 2.2rem;
    background: transparent;
    color: inherit;
    isolation: isolate;
    filter: drop-shadow(0 3rem 5rem rgba(0, 0, 0, 0.38));
    perspective: 80rem;
  }

  .portfolio-folder__back { position: absolute; right: 3%; bottom: 8%; left: 3%; height: 73%; border-radius: 2.2rem; background: linear-gradient(145deg, #343840, #202329); }
  .portfolio-folder__back::before { position: absolute; top: -17%; left: 0; width: 42%; height: 28%; border-radius: 1.5rem 2.4rem 0 0; background: #30343b; content: ''; }
  .portfolio-folder__papers { position: absolute; inset: 16% 9% 19%; overflow: hidden; }
  .portfolio-folder__papers i { position: absolute; right: 0; bottom: 0; left: 0; display: flex; height: 88%; align-items: flex-start; justify-content: space-between; padding: 1.2rem 1.4rem; border-radius: 1.1rem; background: #f0eee7; color: #171717; font-style: normal; transform: translateY(64%); transition: transform 820ms var(--ease-out); }
  .portfolio-folder__papers i:nth-child(1) { z-index: 3; }
  .portfolio-folder__papers i:nth-child(2) { z-index: 2; background: #c72a35; color: #f3f0e8; transform: translateY(72%); }
  .portfolio-folder__papers i:nth-child(3) { z-index: 1; background: #e4b91f; transform: translateY(80%); }
  .portfolio-folder__papers small,
  .portfolio-folder__papers b { font-size: 0.52rem; letter-spacing: 0.13em; }
  .portfolio-folder__papers b { font-weight: 760; }

  .portfolio-folder__front { position: absolute; z-index: 5; right: 1%; bottom: 1%; left: 1%; height: 48%; overflow: hidden; border-radius: 1.8rem 1.8rem 2.3rem 2.3rem; background: radial-gradient(circle at 84% 20%, rgba(228, 185, 31, 0.25), transparent 30%), radial-gradient(circle at 12% 90%, rgba(181, 31, 43, 0.34), transparent 36%), #282c33; box-shadow: inset 0 1px rgba(255, 255, 255, 0.12); transform-origin: bottom center; transition: transform 900ms var(--ease-out); }
  .portfolio-folder__front::after { position: absolute; inset: 0; background: linear-gradient(112deg, transparent 34%, rgba(255, 255, 255, 0.15) 49%, transparent 64%); background-position: 140% 0; background-size: 240% 100%; content: ''; transition: background-position 1000ms var(--ease-out); }
  .portfolio-folder__front small { position: absolute; top: 1.5rem; left: 1.6rem; font-size: 0.54rem; letter-spacing: 0.16em; }
  .portfolio-folder__front strong { position: absolute; bottom: -0.12em; left: 4%; color: rgba(247, 245, 239, 0.13); font-size: clamp(5rem, 12vw, 11rem); font-weight: 780; line-height: 0.82; letter-spacing: -0.07em; }
  .portfolio-folder__action { position: absolute; z-index: 9; right: 1.6rem; bottom: 32%; display: grid; width: 2.8rem; aspect-ratio: 1; place-items: center; padding: 0; border: 0; border-radius: 50%; background: var(--yellow); color: #171717; font: inherit; font-size: 1rem; cursor: pointer; transition: rotate 520ms var(--ease-out), scale 520ms var(--ease-out), background 360ms ease; }
  .portfolio-folder:hover .portfolio-folder__front::after,
  .portfolio-folder:focus-visible .portfolio-folder__front::after { background-position: -40% 0; }
  .portfolio-folder:hover .portfolio-folder__action,
  .portfolio-folder__action:focus-visible { rotate: 45deg; scale: 1.08; background: #f3f0e8; }
  .folder-intro.is-open .portfolio-folder__papers i:nth-child(1) { transform: translateY(4%); }
  .folder-intro.is-open .portfolio-folder__papers i:nth-child(2) { transform: translateY(18%); }
  .folder-intro.is-open .portfolio-folder__papers i:nth-child(3) { transform: translateY(32%); }
  .folder-intro.is-open .portfolio-folder__front { transform: rotateX(-7deg) translateY(0.8rem); }
  .folder-intro.is-open .portfolio-folder__action { rotate: 90deg; }

  .work-browser { display: grid; grid-template-columns: minmax(20rem, 0.78fr) minmax(32rem, 1.22fr); gap: clamp(3rem, 7vw, 8rem); align-items: start; margin-top: clamp(3.5rem, 6vw, 6rem); }
  .work-index { display: grid; }
  .work-row { position: relative; }
  .work-row::after { position: absolute; right: 8%; bottom: 0; left: 8%; height: 1.1rem; background: radial-gradient(ellipse, rgba(247, 245, 239, 0.12), transparent 70%); content: ''; opacity: 0; transition: opacity 420ms ease, transform 620ms var(--ease-out); transform: scaleX(0.65); }
  .work-row.is-active::after { opacity: 1; transform: scaleX(1); }
  .work-row button { display: grid; width: 100%; grid-template-columns: 2.2rem 1fr auto; gap: 0.9rem; align-items: start; padding: 1.5rem 0; border: 0; background: transparent; color: rgba(247, 245, 239, 0.27); text-align: left; cursor: pointer; transition: color 480ms ease, transform 620ms var(--ease-out); }
  .work-row button > span:first-child,
  .work-row button small { padding-top: 0.42rem; font-size: 0.5rem; letter-spacing: 0.12em; }
  .work-row button small { color: var(--yellow); text-transform: uppercase; }
  .work-row__title { min-width: 0; font-size: clamp(1.75rem, 3.2vw, 3.45rem); font-weight: 520; line-height: 0.98; letter-spacing: -0.058em; overflow-wrap: anywhere; }
  .work-row.is-active button,
  .work-row button:hover,
  .work-row button:focus-visible { color: var(--white); transform: translateX(0.4rem); }
  .work-row__detail { display: grid; grid-template-rows: 0fr; opacity: 0; transition: grid-template-rows 650ms var(--ease-out), opacity 450ms ease; }
  .work-row__detail > div { min-height: 0; overflow: hidden; }
  .work-row.is-active .work-row__detail { grid-template-rows: 1fr; opacity: 1; }
  .work-row__detail p { display: grid; grid-template-columns: 4.2rem minmax(0, 1fr); gap: 0.7rem; margin: 0 0 0.75rem 3.1rem; color: rgba(247, 245, 239, 0.58); font-size: 0.72rem; line-height: 1.55; }
  .work-row__detail p span { color: rgba(247, 245, 239, 0.32); font-size: 0.48rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .work-row__detail ul { display: flex; flex-wrap: wrap; gap: 0.45rem 1rem; margin: 1rem 0 1.5rem 3.1rem; padding: 0; color: rgba(247, 245, 239, 0.7); font-size: 0.62rem; list-style: none; }
  .work-row__detail li::before { display: inline-block; width: 0.28rem; height: 0.28rem; margin-right: 0.45rem; border-radius: 50%; background: var(--yellow); content: ''; }

  .work-preview-stage { position: sticky; top: 3vh; min-height: clamp(31rem, 42vw, 40rem); }
  .work-preview-caption { display: block; margin: 0 0 1rem; color: rgba(247, 245, 239, 0.4); font-size: 0.48rem; letter-spacing: 0.14em; }
  .case-preview { position: absolute; top: 1.5rem; right: 0; left: 0; opacity: 0; visibility: hidden; transform: translateY(1.5rem) scale(0.975); transition: opacity 520ms ease, transform 800ms var(--ease-out), visibility 0s 800ms; }
  .case-preview.is-active { z-index: 2; opacity: 1; visibility: visible; transform: none; transition-delay: 0s; }
  .case-preview__meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.7rem; color: rgba(247, 245, 239, 0.45); font-size: 0.5rem; letter-spacing: 0.08em; }
  .case-preview__meta strong { color: var(--yellow); }

  @media (max-width: 63.99rem) {
    .work-heading { grid-template-columns: 1fr; }
    .work-heading > p { max-width: 34rem; margin-top: 1.25rem; }
    .work-browser { grid-template-columns: minmax(18rem, 0.9fr) minmax(24rem, 1.1fr); gap: 2.5rem; }
    .work-preview-stage { min-height: 33rem; }
  }

  @media (max-width: 47.99rem) {
    .selected-work { padding-top: 8rem; }
    .work-heading h2 { font-size: clamp(2.9rem, 14vw, 4.7rem); }
    .folder-intro { min-height: 24rem; }
    .portfolio-folder { width: 96%; border-radius: 1.3rem; }
    .portfolio-folder__front { border-radius: 1.2rem 1.2rem 1.6rem 1.6rem; }
    .portfolio-folder__front small { top: 1rem; left: 1rem; }
    .portfolio-folder__action { right: 1rem; bottom: 31%; width: 2.2rem; }
    .work-browser { grid-template-columns: 1fr; margin-top: 5rem; }
    .work-row button { grid-template-columns: 1.7rem 1fr; gap: 0.55rem; }
    .work-row button small { display: none; }
    .work-row__title { font-size: clamp(1.65rem, 8vw, 2.6rem); }
    .work-row__detail p { grid-template-columns: 1fr; gap: 0.3rem; margin-left: 2.25rem; }
    .work-row__detail ul { margin-left: 2.25rem; }
    .work-preview-stage { position: relative; top: auto; min-height: 23rem; }
    .case-preview { top: 1.4rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-folder__papers i,
    .portfolio-folder__front,
    .portfolio-folder__front::after,
    .portfolio-folder__action,
    .work-row button,
    .work-row__detail,
    .case-preview { transition: none; }
  }
</style>
