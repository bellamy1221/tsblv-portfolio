---
import { conceptCases } from '../data/home';
import ProjectPreview from './ProjectPreview.astro';
---

<section class="selected-work" id="work" aria-labelledby="work-title">
  <div class="site-container content-grid work-heading" data-motion="clip">
    <div>
      <p class="section-label">Практика</p>
      <h2 id="work-title">Избранные проекты</h2>
    </div>
    <p>Концепции показывают мой подход к структуре, дизайну и рабочим системам. Это не реальные клиентские проекты.</p>
  </div>

  <div class="case-list">
    {conceptCases.map((project, index) => (
      <article class:list={['case-study', `case-study--${index + 1}`]} data-sequence>
        <div class="site-container case-title" data-motion="clip">
          <div class="case-index"><span>{project.id}</span><strong>{project.kind}</strong></div>
          <p>{project.type}</p>
          <h3>{project.title}</h3>
        </div>

        <div class="site-container case-scene" data-project-scene data-motion="scene">
          <div class="case-preview" data-project-layer="back">
            <ProjectPreview kind={project.preview} />
          </div>
          {index === 1 && (
            <>
              <span class="scene-fragment scene-fragment--one" data-project-layer="front" aria-hidden="true"><i></i><i></i><b></b></span>
              <span class="scene-fragment scene-fragment--two" data-project-layer="front" aria-hidden="true"><i></i><b></b><b></b></span>
            </>
          )}
        </div>

        <div class="site-container content-grid case-details" data-motion="text">
          <dl>
            <div><dt>Задача</dt><dd>{project.task}</dd></div>
            <div><dt>Решение</dt><dd>{project.solution}</dd></div>
          </dl>
          <div class="case-more">
            <button type="button" aria-expanded="false" data-case-toggle>
              Услуги проекта <span aria-hidden="true">+</span>
            </button>
            <div class="case-services" data-case-panel>
              <div><ul aria-label="Услуги">{project.services.map((service) => <li>{service}</li>)}</ul></div>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .selected-work {
    position: relative;
    overflow: hidden;
    padding: clamp(6rem, 9vw, 9rem) 0;
    color: var(--white);
  }

  .selected-work::before {
    position: absolute;
    z-index: -2;
    inset: -18rem 0;
    background:
      conic-gradient(from 224deg at 76% 34%, transparent 0 28%, rgba(228, 185, 31, 0.08) 34%, rgba(247, 245, 239, 0.08) 39%, rgba(181, 31, 43, 0.08) 45%, transparent 53% 100%),
      linear-gradient(180deg, transparent, rgba(21, 24, 29, 0.96) 12rem, var(--dark) 26rem, var(--dark) calc(100% - 20rem), transparent);
    content: '';
    pointer-events: none;
  }

  .work-heading {
    align-items: end;
    margin-bottom: clamp(4.5rem, 7vw, 7rem);
  }

  .work-heading > div {
    grid-column: 1 / span 8;
  }

  .work-heading > p {
    grid-column: 9 / -1;
    margin: 0;
    color: rgba(247, 245, 239, 0.64);
    font-size: 0.88rem;
    line-height: 1.62;
  }

  .selected-work .section-label {
    color: var(--yellow);
  }

  .case-list {
    display: grid;
    gap: clamp(7rem, 12vw, 12rem);
  }

  .case-study {
    position: relative;
  }

  .case-title {
    position: relative;
    z-index: 3;
  }

  .case-index {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--line-dark);
  }

  .case-index span {
    color: rgba(247, 245, 239, 0.54);
    font-size: 0.62rem;
  }

  .case-index strong {
    color: var(--yellow);
    font-size: 0.59rem;
    font-weight: 760;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .case-title > p {
    margin: 1.2rem 0 0.6rem;
    color: rgba(247, 245, 239, 0.55);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .case-title h3 {
    max-width: 72rem;
    margin: 0;
    font-size: clamp(3rem, 7.8vw, 8.5rem);
    font-weight: 520;
    line-height: 0.88;
    letter-spacing: -0.078em;
  }

  .case-scene {
    --project-x: 0px;
    --project-y: 0px;
    --project-back-x: 0px;
    --project-back-y: 0px;
    --project-front-x: 0px;
    --project-front-y: 0px;
    --pointer-x: 50%;
    --pointer-y: 50%;
    position: relative;
    margin-top: clamp(2rem, 4vw, 4rem);
  }

  .case-scene::after {
    position: absolute;
    z-index: 5;
    inset: -1px;
    background:
      radial-gradient(circle at var(--pointer-x) var(--pointer-y), rgba(255, 255, 255, 0.16), transparent 21%),
      linear-gradient(112deg, rgba(181, 31, 43, 0.16), transparent 14% 82%, rgba(228, 185, 31, 0.16));
    content: '';
    opacity: 0.42;
    pointer-events: none;
    transition: opacity 320ms ease;
  }

  .case-scene:hover::after {
    opacity: 0.74;
  }

  .case-preview {
    position: relative;
    z-index: 1;
    transform: translate(var(--project-back-x), var(--project-back-y));
    transition: transform 520ms var(--ease-out), filter 420ms ease;
  }

  .case-scene:hover .case-preview {
    filter: contrast(1.025) saturate(1.03);
  }

  .case-study--1 .case-scene {
    width: min(calc(100% - var(--gutter)), 95rem);
    margin-right: 0;
  }

  .case-study--1 .case-preview :global(.browser-preview) {
    min-height: clamp(28rem, 58vw, 52rem);
  }

  .case-study--2 .case-title {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 1.5rem;
  }

  .case-study--2 .case-index,
  .case-study--2 .case-title > p {
    grid-column: 1 / span 4;
  }

  .case-study--2 .case-title h3 {
    grid-column: 4 / -1;
    margin-top: -1.2rem;
  }

  .case-study--2 .case-scene {
    width: min(76rem, calc(100% - var(--gutter) * 2));
    margin-right: 3vw;
  }

  .case-study--2 .case-preview {
    transform: translate(calc(var(--project-back-x) - 2vw), var(--project-back-y)) rotate(-1.2deg);
  }

  .scene-fragment {
    position: absolute;
    z-index: 4;
    display: grid;
    gap: 0.65rem;
    padding: 1rem;
    border: 1px solid rgba(247, 245, 239, 0.3);
    background: rgba(32, 36, 42, 0.9);
    box-shadow: 0 1.5rem 3.5rem rgba(0, 0, 0, 0.28);
    transform: translate(var(--project-x), var(--project-y));
    transition: transform 520ms var(--ease-out);
  }

  .scene-fragment i,
  .scene-fragment b {
    display: block;
    height: 0.4rem;
    background: rgba(247, 245, 239, 0.28);
  }

  .scene-fragment i { width: 65%; background: var(--yellow); }
  .scene-fragment b:nth-child(odd) { width: 82%; }

  .scene-fragment--one {
    top: 13%;
    right: -3vw;
    width: clamp(8rem, 16vw, 15rem);
    transform: translate(var(--project-front-x), var(--project-front-y)) rotate(3deg);
  }

  .scene-fragment--two {
    bottom: -5%;
    left: 8%;
    width: clamp(7rem, 13vw, 12rem);
    transform: translate(var(--project-x), var(--project-y)) rotate(-4deg);
  }

  .case-study--3 {
    padding-block: clamp(2rem, 5vw, 5rem);
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.025) 18% 82%, transparent);
  }

  .case-study--3 .case-title h3 {
    max-width: 64rem;
  }

  .case-study--3 .case-scene {
    width: min(calc(100% - var(--gutter)), 88rem);
    margin-left: auto;
  }

  .case-details {
    align-items: start;
    margin-top: clamp(2rem, 4vw, 3.5rem);
    padding-top: 1.25rem;
    border-top: 1px solid var(--line-dark);
  }

  .case-details dl {
    display: grid;
    grid-column: 1 / span 9;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    margin: 0;
  }

  .case-details dl > div {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1rem;
  }

  .case-details dt {
    color: rgba(247, 245, 239, 0.48);
    font-size: 0.62rem;
  }

  .case-details dd {
    margin: 0;
    color: rgba(247, 245, 239, 0.82);
    font-size: 0.88rem;
    line-height: 1.58;
  }

  .case-more {
    grid-column: 10 / -1;
  }

  .case-more button {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    padding: 0 0 0.75rem;
    border: 0;
    border-bottom: 1px solid var(--line-dark);
    background: transparent;
    color: var(--white);
    font-size: 0.7rem;
    font-weight: 700;
    cursor: pointer;
  }

  .case-more button span {
    color: var(--yellow);
    font-size: 1.1rem;
    transition: transform 360ms var(--ease-out);
  }

  .case-more button[aria-expanded='true'] span {
    transform: rotate(45deg);
  }

  .case-services {
    display: grid;
    grid-template-rows: 1fr;
    opacity: 1;
    transition: grid-template-rows 440ms var(--ease-out), opacity 300ms ease;
  }

  .case-services.is-collapsible {
    grid-template-rows: 0fr;
    opacity: 0;
  }

  .case-services.is-collapsible.is-open {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .case-services > div {
    min-height: 0;
    overflow: hidden;
  }

  .case-services ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0.85rem 0 0;
    color: rgba(247, 245, 239, 0.64);
    font-size: 0.68rem;
    list-style: none;
  }

  @media (max-width: 63.99rem) {
    .work-heading > div,
    .work-heading > p {
      grid-column: 1 / -1;
    }

    .work-heading > p {
      max-width: 34rem;
      margin-top: 1.25rem;
    }

    .case-details dl,
    .case-more {
      grid-column: 1 / -1;
    }

    .case-more {
      margin-top: 1.5rem;
    }
  }

  @media (max-width: 47.99rem) {
    .selected-work {
      padding-block: 5.5rem;
    }

    .case-list {
      gap: 6rem;
    }

    .case-title h3 {
      font-size: clamp(2.8rem, 14vw, 4.5rem);
    }

    .case-study--2 .case-title {
      display: block;
    }

    .case-study--2 .case-title h3 {
      margin-top: 0;
    }

    .case-study--1 .case-scene,
    .case-study--2 .case-scene,
    .case-study--3 .case-scene {
      width: calc(100% - 0.5rem);
      margin-inline: auto;
    }

    .case-study--2 .case-preview {
      transform: translate(var(--project-back-x), var(--project-back-y));
    }

    .scene-fragment {
      display: none;
    }

    .case-details {
      display: block;
    }

    .case-details dl {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .case-details dl > div {
      grid-template-columns: 3.5rem 1fr;
    }
  }
</style>
