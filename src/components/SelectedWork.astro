---
import { conceptCases } from '../data/home';
import ProjectPreview from './ProjectPreview.astro';
---

<section class="section selected-work" id="work" aria-labelledby="work-title">
  <div class="site-container">
    <div class="work-heading" data-reveal="mask">
      <div><p class="section-label">Практика</p><h2 id="work-title">Избранные проекты</h2></div>
      <p>Концепции показывают мой подход к структуре, дизайну и рабочим системам. Это не реальные клиентские проекты.</p>
    </div>

    <div class="case-list">
      {conceptCases.map((project, index) => <article class:list={['case-study', index % 2 === 1 && 'case-study--reverse']} data-reveal="depth">
        <div class="case-preview"><ProjectPreview kind={project.preview} /></div>
        <div class="case-copy">
          <div class="case-topline"><span>{project.id}</span><strong>{project.kind}</strong></div>
          <p class="case-type">{project.type}</p><h3>{project.title}</h3>
          <button class="case-toggle" type="button" aria-expanded="false" data-case-toggle>Подробнее о концепте <span aria-hidden="true">+</span></button>
          <div class="case-details" data-case-details>
            <dl><div><dt>Задача</dt><dd>{project.task}</dd></div><div><dt>Решение</dt><dd>{project.solution}</dd></div></dl>
            <ul aria-label="Услуги">{project.services.map((service) => <li>{service}</li>)}</ul>
          </div>
        </div>
      </article>)}
    </div>
  </div>
</section>

<style>
  .selected-work { overflow:hidden; background:linear-gradient(180deg,color-mix(in srgb,var(--surface-inverse) 22%,transparent),var(--surface-inverse) 15%,var(--surface-inverse) 85%,color-mix(in srgb,var(--surface-inverse) 20%,transparent)); color:var(--on-inverse); }.selected-work::before { position:absolute; z-index:0; inset:-10% 0; background:radial-gradient(circle at 10% 12%,color-mix(in srgb,var(--violet) 46%,transparent),transparent 33%),radial-gradient(circle at 85% 70%,color-mix(in srgb,var(--cyan) 22%,transparent),transparent 34%); content:''; pointer-events:none; }.selected-work .site-container { position:relative; z-index:1; }.work-heading { display:flex; align-items:end; justify-content:space-between; gap:2rem; margin-bottom:clamp(2.5rem,5vw,4rem); }.work-heading .section-label { color:#c2b9df; }.work-heading>p { max-width:30rem; margin:0; color:#d0c9db; font-size:.9rem; line-height:1.6; }.case-list { display:grid; gap:clamp(3.5rem,7vw,6.5rem); }.case-study { display:grid; gap:clamp(2rem,4vw,4rem); }.case-preview { position:relative; transition:transform .55s cubic-bezier(.22,1,.36,1),filter .45s ease; }.case-preview::after { position:absolute; inset:8%; border:1px solid rgba(255,255,255,.16); border-radius:1.2rem; content:''; pointer-events:none; transform:rotate(-2deg); transition:transform .55s cubic-bezier(.22,1,.36,1); }.case-study:hover .case-preview,.case-study:focus-within .case-preview { filter:saturate(1.08); transform:translateY(-.55rem) rotate(.5deg); }.case-study:hover .case-preview::after { transform:rotate(2deg) scale(1.03); }.case-copy { align-self:center; }.case-topline { display:flex; align-items:center; justify-content:space-between; padding-bottom:1rem; border-bottom:1px solid rgba(255,255,255,.18); }.case-topline>span { color:#b8b0c5; font-size:.65rem; }.case-topline strong { padding:.35rem .55rem; border:1px solid #7d729c; border-radius:999px; color:#ded2ff; font-size:.58rem; letter-spacing:.09em; text-transform:uppercase; }.case-type { margin:1.2rem 0 .55rem; color:#c6bed1; font-size:.65rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; }.case-copy h3 { max-width:32rem; margin:0; font-size:clamp(2rem,4vw,4rem); font-weight:520; line-height:1; letter-spacing:-.055em; }.case-toggle { display:inline-flex; align-items:center; gap:.6rem; margin-top:1.4rem; padding:.65rem 0; border:0; border-bottom:1px solid #82799a; background:transparent; color:#eee8ff; font:700 .76rem var(--font-sans); cursor:pointer; }.case-toggle span { font-size:1.1rem; transition:transform .2s ease; }.case-toggle[aria-expanded='true'] span { transform:rotate(45deg); }.case-details[hidden] { display:none; }.case-details dl { display:grid; gap:1.2rem; margin:1.5rem 0; }.case-details dl>div { display:grid; grid-template-columns:4rem 1fr; gap:1rem; }.case-details dt { color:#b7b0c0; font-size:.65rem; }.case-details dd { margin:0; color:#f0ebf5; font-size:.88rem; line-height:1.55; }.case-details ul { display:flex; flex-wrap:wrap; gap:.45rem; margin:0; padding:0; list-style:none; }.case-details li { padding:.45rem .65rem; border:1px solid rgba(255,255,255,.19); border-radius:999px; color:#e0d9e9; font-size:.62rem; }@media(min-width:64rem) { .case-study { grid-template-columns:minmax(0,1.5fr) minmax(19rem,.5fr); align-items:center; }.case-study--reverse { grid-template-columns:minmax(19rem,.5fr) minmax(0,1.5fr); }.case-study--reverse .case-preview { order:2; } }@media(max-width:47.99rem) { .work-heading { align-items:flex-start; flex-direction:column; } }
</style>
