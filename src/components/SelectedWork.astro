---
import { conceptCases } from '../data/home';
import ProjectPreview from './ProjectPreview.astro';
---

<section class="section selected-work" id="work" aria-labelledby="work-title">
  <div class="site-container">
    <div class="work-heading" data-reveal="mask">
      <div><p class="section-label">Практика</p><h2 id="work-title">Избранные проекты</h2></div>
      <p>Концепции показывают мой подход к структуре, дизайну и рабочим системам. Это не реальные клиентские проекты.</p>
    </div>

    <div class="case-list">
      {conceptCases.map((project, index) => (
        <article class:list={['case-study', index % 2 === 1 && 'case-study--reverse']} data-reveal="depth">
          <div class="case-preview"><ProjectPreview kind={project.preview} /></div>
          <div class="case-copy">
            <div class="case-topline"><span>{project.id}</span><strong>{project.kind}</strong></div>
            <p class="case-type">{project.type}</p>
            <h3>{project.title}</h3>
            <dl>
              <div><dt>Задача</dt><dd>{project.task}</dd></div>
              <div><dt>Решение</dt><dd>{project.solution}</dd></div>
            </dl>
            <ul aria-label="Услуги">{project.services.map((service) => <li>{service}</li>)}</ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .selected-work { overflow:hidden; background: radial-gradient(circle at 10% 10%, #413966, transparent 34%), var(--surface-inverse); color: var(--on-inverse); }
  .work-heading { display: flex; align-items: end; justify-content: space-between; gap: 2rem; margin-bottom: clamp(3rem, 7vw, 6rem); }
  .work-heading .section-label { color: #9fa29b; }
  .work-heading > p { max-width: 30rem; margin: 0; color: #aeb1aa; font-size: .9rem; line-height: 1.6; }
  .case-list { display: grid; gap: clamp(5rem, 11vw, 10rem); }
  .case-study { display: grid; gap: clamp(2rem, 4vw, 4rem); }
  .case-preview { position:relative; transition: transform .55s cubic-bezier(.22,1,.36,1), filter .45s ease; }
  .case-preview::after{position:absolute;inset:8%;border:1px solid rgba(255,255,255,.16);border-radius:1.2rem;pointer-events:none;content:'';transform:rotate(-2deg);transition:transform .55s cubic-bezier(.22,1,.36,1)}
  .case-study:hover .case-preview, .case-study:focus-within .case-preview { filter: saturate(1.08); transform: translateY(-.8rem) rotate(.5deg); }.case-study:hover .case-preview::after{transform:rotate(2deg) scale(1.03)}
  .case-study:hover .case-topline strong, .case-study:focus-within .case-topline strong { border-color: #91a5ff; color: #d8e0ff; }
  .case-copy { align-self: center; }
  .case-topline { display: flex; align-items: center; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid #343632; }
  .case-topline span { color: #858881; font-size: .65rem; }
  .case-topline strong { padding: .35rem .55rem; border: 1px solid #5d6380; border-radius: 999px; color: #aebeff; font-size: .58rem; letter-spacing: .09em; text-transform: uppercase; }
  .case-type { margin: 1.4rem 0 .55rem; color: #9b9e97; font-size: .65rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; }
  h3 { max-width: 32rem; margin: 0; font-size: clamp(2rem, 4vw, 4rem); font-weight: 520; line-height: 1; letter-spacing: -.055em; }
  dl { display: grid; gap: 1.2rem; margin: 2rem 0; }
  dl > div { display: grid; grid-template-columns: 4rem 1fr; gap: 1rem; }
  dt { color: #868982; font-size: .65rem; }
  dd { margin: 0; color: #c7c9c3; font-size: .88rem; line-height: 1.55; }
  ul { display: flex; flex-wrap: wrap; gap: .45rem; margin: 0; padding: 0; list-style: none; }
  li { padding: .45rem .65rem; border: 1px solid #3b3e39; border-radius: 999px; color: #b6b8b2; font-size: .62rem; }
  @media (min-width: 64rem) {
    .case-study { grid-template-columns: minmax(0, 1.5fr) minmax(19rem, .5fr); align-items: center; }
    .case-study--reverse { grid-template-columns: minmax(19rem, .5fr) minmax(0, 1.5fr); }
    .case-study--reverse .case-preview { order: 2; }
  }
  @media (max-width: 47.99rem) { .work-heading { align-items: flex-start; flex-direction: column; } }
</style>
