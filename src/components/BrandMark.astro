---
interface Props {
  variant?: 'full' | 'wordmark' | 'symbol';
  size?: 'small' | 'medium' | 'large';
  orientation?: 'horizontal' | 'vertical';
  href?: string | null;
  class?: string;
  ariaLabel?: string;
  motion?: 'header' | 'full' | 'none';
}

const {
  variant = 'full',
  size = 'medium',
  orientation = 'horizontal',
  href = '/',
  class: className,
  ariaLabel = 'TSBLV — независимая digital-студия',
  motion = 'none',
} = Astro.props;

const Element = href === null ? 'span' : 'a';
const accessibleName = variant === 'full'
  ? 'TSBLV, независимая digital-студия из Северной Осетии'
  : ariaLabel;
const isDecorative = href === null;
---

<Element
  href={href ?? undefined}
  class:list={[
    'brand-mark',
    `brand-mark--${variant}`,
    `brand-mark--${size}`,
    `brand-mark--${orientation}`,
    motion === 'header' && 'header-brand',
    motion === 'full' && 'brand-mark--motion-full',
    className,
  ]}
  data-reveal={motion === 'header' ? 'clip' : undefined}
  data-delay={motion === 'header' ? '160' : undefined}
  aria-hidden={isDecorative ? 'true' : undefined}
>
  {!isDecorative && <span class="brand-sr-only">{accessibleName}</span>}

  <span class="brand-visual" aria-hidden="true">
    {variant === 'wordmark' && (
      <span class="brand-wordmark" data-brand-part={motion === 'full' ? 'wordmark' : undefined}>TSBLV</span>
    )}

    {variant === 'symbol' && <span class="brand-symbol">Æ</span>}

    {variant === 'full' && (
      <>
        <span class="brand-wordmark" data-brand-part={motion === 'full' ? 'wordmark' : undefined}>TSBLV</span>
        <span class="brand-divider" data-brand-part={motion === 'full' ? 'divider' : undefined}></span>
        <span class="brand-origin">
          <span class="brand-symbol" data-brand-part={motion === 'full' ? 'symbol' : undefined}>Æ</span>
          <span class="brand-captions">
            <span data-brand-part={motion === 'full' ? 'caption' : undefined} data-caption-index="0">NORTH OSSETIA</span>
            <span data-brand-part={motion === 'full' ? 'caption' : undefined} data-caption-index="1">WORLDWIDE</span>
          </span>
        </span>
      </>
    )}
  </span>
</Element>

<style>
  .brand-mark {
    display: inline-flex;
    max-width: 100%;
    align-items: center;
    color: var(--color-text);
    line-height: 1;
    text-decoration: none;
  }

  .brand-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .brand-visual {
    display: inline-flex;
    max-width: 100%;
    align-items: center;
  }

  .brand-wordmark,
  .brand-symbol {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: normal;
    text-shadow: none;
    white-space: nowrap;
  }

  .brand-wordmark {
    color: var(--color-text);
    font-size: var(--brand-wordmark-size);
    letter-spacing: 0.085em;
  }

  .brand-symbol {
    color: var(--color-accent);
    font-size: var(--brand-symbol-size);
    letter-spacing: 0;
  }

  .brand-origin {
    display: inline-flex;
    min-width: 0;
    align-items: center;
    gap: var(--brand-origin-gap);
  }

  .brand-captions {
    display: grid;
    gap: 0.1em;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--brand-caption-size);
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: var(--brand-caption-tracking);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .brand-divider {
    flex: 0 0 auto;
    width: 1px;
    height: var(--brand-divider-length);
    background: var(--color-line-strong);
  }

  .brand-mark--horizontal .brand-visual {
    flex-direction: row;
    gap: var(--brand-gap);
  }

  .brand-mark--vertical .brand-visual {
    align-items: flex-start;
    flex-direction: column;
    gap: var(--brand-stack-gap);
  }

  .brand-mark--vertical .brand-divider {
    width: min(var(--brand-divider-horizontal), 100%);
    height: 1px;
  }

  .brand-mark--small {
    --brand-wordmark-size: clamp(1.5rem, 2vw, 1.75rem);
    --brand-symbol-size: 1.5rem;
    --brand-caption-size: var(--font-size-caption);
    --brand-caption-tracking: 0.2em;
    --brand-gap: 0.75rem;
    --brand-stack-gap: 0.65rem;
    --brand-origin-gap: 0.55rem;
    --brand-divider-length: 2.4rem;
    --brand-divider-horizontal: 5rem;
  }

  .brand-mark--medium {
    --brand-wordmark-size: clamp(2.375rem, 4vw, 3.25rem);
    --brand-symbol-size: clamp(2rem, 3vw, 2.65rem);
    --brand-caption-size: clamp(0.6875rem, 0.7vw, 0.8125rem);
    --brand-caption-tracking: 0.22em;
    --brand-gap: clamp(1rem, 2vw, 1.5rem);
    --brand-stack-gap: 0.9rem;
    --brand-origin-gap: 0.75rem;
    --brand-divider-length: 3.4rem;
    --brand-divider-horizontal: 7rem;
  }

  .brand-mark--large {
    --brand-wordmark-size: clamp(4.375rem, 7vw, 6.25rem);
    --brand-symbol-size: clamp(3rem, 5vw, 4.5rem);
    --brand-caption-size: clamp(0.6875rem, 0.8vw, 0.8125rem);
    --brand-caption-tracking: 0.24em;
    --brand-gap: clamp(1.5rem, 3vw, 2.5rem);
    --brand-stack-gap: 1.25rem;
    --brand-origin-gap: 1rem;
    --brand-divider-length: 5rem;
    --brand-divider-horizontal: 10rem;
  }

  @media (max-width: 28rem) {
    .brand-mark--full.brand-mark--horizontal .brand-visual {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--brand-stack-gap);
    }

    .brand-mark--full.brand-mark--horizontal .brand-divider {
      width: min(var(--brand-divider-horizontal), 100%);
      height: 1px;
    }
  }
</style>
