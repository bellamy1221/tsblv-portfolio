---
interface Props {
  variant?: 'full' | 'wordmark' | 'symbol';
  size?: 'small' | 'medium' | 'large';
  orientation?: 'horizontal' | 'vertical';
  href?: string | null;
  class?: string;
  ariaLabel?: string;
}

const {
  variant = 'full',
  size = 'medium',
  orientation = 'horizontal',
  href = '/',
  class: className,
  ariaLabel = 'TSBLV',
} = Astro.props;

const Element = href === null ? 'span' : 'a';
const accessibleName = variant === 'full' ? 'TSBLV — Северная Осетия, работаю по всему миру' : ariaLabel;
---

<Element
  href={href ?? undefined}
  class:list={['brand-mark', `brand-mark--${variant}`, `brand-mark--${size}`, `brand-mark--${orientation}`, className]}
  aria-label={href === null ? undefined : accessibleName}
  aria-hidden={href === null ? 'true' : undefined}
>
  {variant !== 'symbol' && <span class="brand-wordmark">TSBLV</span>}
  {variant === 'full' && <span class="brand-divider" aria-hidden="true"></span>}
  {variant !== 'wordmark' && (
    <span class="brand-origin" aria-hidden="true">
      <span class="brand-symbol">Æ</span>
      {variant === 'full' && (
        <span class="brand-caption"><span>NORTH OSSETIA</span><span>WORLDWIDE</span></span>
      )}
    </span>
  )}
</Element>

<style>
  .brand-mark { display: inline-flex; align-items: center; color: var(--ink); line-height: 1; text-decoration: none; }
  .brand-wordmark { font-size: var(--mark-size); font-weight: 720; letter-spacing: -0.055em; }
  .brand-divider { width: 1px; height: var(--divider-size); background: var(--line-strong); }
  .brand-origin { display: inline-flex; align-items: center; gap: .6rem; }
  .brand-symbol { color: var(--accent); font-size: calc(var(--mark-size) * .86); font-weight: 620; letter-spacing: -.06em; }
  .brand-caption { display: grid; gap: .17rem; color: var(--muted); font-size: var(--caption-size); font-weight: 650; line-height: 1; letter-spacing: .14em; }
  .brand-mark--horizontal { gap: var(--mark-gap); }
  .brand-mark--vertical { align-items: flex-start; flex-direction: column; gap: .85rem; }
  .brand-mark--vertical .brand-divider { width: 4rem; height: 1px; }
  .brand-mark--small { --mark-size: 1.1rem; --caption-size: .45rem; --divider-size: 1.65rem; --mark-gap: .65rem; }
  .brand-mark--medium { --mark-size: clamp(1.65rem, 3vw, 2.4rem); --caption-size: .56rem; --divider-size: 2.5rem; --mark-gap: 1rem; }
  .brand-mark--large { --mark-size: clamp(2.6rem, 6vw, 5.25rem); --caption-size: .64rem; --divider-size: 4.5rem; --mark-gap: clamp(1.2rem, 2vw, 2rem); }
  @media (max-width: 24rem) {
    .brand-mark--full.brand-mark--horizontal { align-items: flex-start; flex-direction: column; }
    .brand-mark--full.brand-mark--horizontal .brand-divider { width: 4rem; height: 1px; }
  }
</style>
