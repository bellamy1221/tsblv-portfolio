---
import { Image } from 'astro:assets';
import type { Project } from '../../lib/projects';

interface Props {
  project: Project;
  headingLevel?: 'h2' | 'h3';
  featured?: boolean;
}

const { project, headingLevel = 'h3', featured = false } = Astro.props;
const Heading = headingLevel;
const { title, shortTitle, category, year, summary, cover, coverAlt, tone } = project.data;
---

<article class="project-card" data-tone={tone} data-featured={featured || undefined} data-reveal="up">
  <a class="project-card-link" href={`/work/${project.id}/`} aria-label={`Открыть проект «${title}»`}>
    <div class="card-media">
      <Image src={cover} alt={coverAlt} width={800} height={600} loading="lazy" decoding="async" />
    </div>
    <div class="card-body">
      <Heading class="card-title">{shortTitle ?? title}</Heading>
      <div class="project-meta">
        <span class="project-category">{category}</span>
        <time class="project-year" datetime={String(year)}>{year}</time>
      </div>
      <p class="card-summary">{summary}</p>
      <span class="project-cta" aria-hidden="true">Смотреть проект</span>
    </div>
  </a>
</article>

<style>
  .project-card {
    min-width: 0;
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    background: var(--color-surface);
    transition: border-color var(--duration-base) var(--ease-standard);
  }

  .project-card[data-tone='dark'] {
    background: var(--color-surface-depth);
  }

  .project-card[data-tone='light'] {
    background: var(--color-surface-soft);
  }

  .project-card[data-tone='warm'] {
    background: linear-gradient(155deg, rgba(42, 40, 36, 0.72), rgba(27, 29, 28, 0.92));
  }

  .project-card[data-tone='neutral'] {
    background: var(--color-surface);
  }

  .project-card-link {
    display: flex;
    height: 100%;
    flex-direction: column;
    text-decoration: none;
  }

  .card-media {
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border-bottom: 1px solid var(--color-line);
    background: var(--color-bg-deep);
  }

  .project-card[data-featured] .card-media {
    aspect-ratio: 16 / 9;
  }

  .card-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: clamp(1rem, 2vw, 1.5rem);
  }

  .card-title {
    overflow-wrap: anywhere;
    margin: 0 0 0.6rem;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    line-height: 1.1;
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 1rem;
    margin-bottom: 0.65rem;
    color: var(--color-text-subtle);
    font-size: clamp(0.6875rem, 0.12vw + 0.66rem, 0.75rem);
  }

  .project-category {
    color: var(--color-text-muted);
  }

  .card-summary {
    max-width: var(--text-width);
    flex: 1;
    margin: 0;
    color: var(--color-text-muted);
    font-size: min(var(--font-size-body), 1rem);
    line-height: 1.5;
  }

  .project-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.15rem;
    color: var(--color-text);
    font-size: var(--font-size-ui);
  }

  .project-cta::after {
    color: var(--color-accent-soft);
    content: '↗';
  }

  @media (hover: hover) {
    .project-card:hover {
      border-color: var(--color-line-strong);
    }

    .project-card-link:hover .card-media :global(img) {
      transform: scale(1.025);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card-media :global(img),
    .project-card-link:hover .card-media :global(img) {
      transform: none;
      transition: none;
    }
  }
</style>
