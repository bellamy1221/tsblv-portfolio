---
interface Props {
  client?: string;
  services: string[];
  roles: string[];
  duration?: string;
}

const { client, services, roles, duration } = Astro.props;

const metadata = [
  client ? { label: 'Клиент', values: [client] } : undefined,
  { label: 'Услуги', values: services },
  { label: 'Роли', values: roles },
  duration ? { label: 'Длительность', values: [duration] } : undefined,
].filter((item): item is { label: string; values: string[] } => Boolean(item));
---

<section class="section" aria-labelledby="project-meta-title">
  <div class="container">
    <h2 class="section-label" id="project-meta-title" data-reveal="fade">О проекте</h2>
    <dl class="metadata-grid" data-stagger data-stagger-delay="70">
      {metadata.map((item) => (
        <div data-reveal="up">
          <dt>{item.label}</dt>
          <dd>
            <ul class="list-reset">
              {item.values.map((value) => <li>{value}</li>)}
            </ul>
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .metadata-grid { display: grid; grid-template-columns: minmax(0, 1fr); margin: 0; border-top: 1px solid var(--color-border); border-left: 1px solid var(--color-border); }
  .metadata-grid > div { min-width: 0; padding: 1.25rem; border-right: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  dt { margin-bottom: 1rem; color: var(--color-text-muted); font-size: var(--font-size-meta); text-transform: uppercase; }
  dd { margin: 0; }
  li + li { margin-top: 0.25rem; }
  @media (min-width: 48rem) { .metadata-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (min-width: 75rem) { .metadata-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
</style>
