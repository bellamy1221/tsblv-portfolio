---
import type { Project } from '../../lib/projects';
import ProjectCard from './ProjectCard.astro';

interface Props {
  previous?: Project;
  next?: Project;
}

const { previous, next } = Astro.props;
const items = [
  previous ? { label: 'Предыдущий проект', project: previous } : undefined,
  next ? { label: 'Следующий проект', project: next } : undefined,
].filter((item): item is { label: string; project: Project } => Boolean(item));
---

{items.length > 0 && (
  <nav class="section" aria-labelledby="project-navigation-title" data-reveal="up">
    <div class="container">
      <h2 id="project-navigation-title" data-reveal="fade">Другие проекты</h2>
      <ul class="project-list list-reset" data-stagger data-stagger-delay="70">
        {items.map((item) => (
          <li>
            <p class="navigation-label">{item.label}</p>
            <ProjectCard project={item.project} />
          </li>
        ))}
      </ul>
    </div>
  </nav>
)}

<style>
  .navigation-label { margin-bottom: 1rem; color: var(--color-text-muted); font-size: var(--font-size-meta); text-transform: uppercase; }
</style>
