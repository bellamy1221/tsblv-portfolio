---
import { Image, getImage } from 'astro:assets';
import type { Project } from '../lib/projects';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import ProjectHeader from '../components/projects/ProjectHeader.astro';
import ProjectMeta from '../components/projects/ProjectMeta.astro';
import ProjectNavigation from '../components/projects/ProjectNavigation.astro';

interface Props {
  title: string;
  description: string;
  summary?: string;
  cover: ImageMetadata;
  coverAlt: string;
  category: string;
  year: number;
  client?: string;
  services: string[];
  roles: string[];
  duration?: string;
  tone: 'dark' | 'light' | 'warm' | 'neutral';
  previous?: Project;
  next?: Project;
}

const {
  title,
  description,
  summary = description,
  cover,
  coverAlt,
  category,
  year,
  client,
  services,
  roles,
  duration,
  tone,
  previous,
  next,
} = Astro.props;

const pageTitle = `${title} — TSBLV`;
const optimizedOpenGraphImage = Astro.site
  ? await getImage({ src: cover, width: 1200, quality: 85 })
  : undefined;
const openGraphImage = optimizedOpenGraphImage && Astro.site
  ? new URL(optimizedOpenGraphImage.src, Astro.site).toString()
  : undefined;
---

<BaseLayout title={pageTitle} description={description} ogImage={openGraphImage}>
  <Header />
  <main id="main-content" tabindex="-1" data-tone={tone}>
    <article>
      <ProjectHeader title={title} category={category} year={year} summary={summary} />
      <ProjectMeta client={client} services={services} roles={roles} duration={duration} />

      <figure class="project-cover container" data-reveal="clip">
        <Image src={cover} alt={coverAlt} loading="eager" decoding="async" fetchpriority="high" />
      </figure>

      <section class="project-content section" aria-label="Описание проекта">
        <div class="container prose" data-stagger data-stagger-delay="60">
          <slot />
        </div>
      </section>
    </article>

    <ProjectNavigation previous={previous} next={next} />
    <Contact />
  </main>
  <Footer />
</BaseLayout>

<style>
  .project-cover { overflow: hidden; margin-block: var(--section-space-small); border-radius: var(--radius-medium); }
  .project-cover :global(img) { width: 100%; height: auto; }
  .prose { max-width: min(100% - (var(--page-gutter) * 2), var(--text-width)); }
  .prose :global(h2) { margin-top: var(--section-space-small); }
  .prose :global(h2:first-child) { margin-top: 0; }
  .prose :global(p) { max-width: var(--text-width); color: var(--color-text-muted); }
  .prose :global(img) { width: 100%; height: auto; margin-block: 2rem; }
</style>
