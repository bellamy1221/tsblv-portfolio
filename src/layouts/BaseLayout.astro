---
import '../styles/global.css';
import '../styles/motion.css';
import MotionProvider from '../components/MotionProvider.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'TSBLV — независимая digital-студия',
  description = 'TSBLV создаёт цифровые продукты, бренды и сайты для амбициозных компаний.',
  lang = 'ru',
  ogImage,
  noindex = false,
} = Astro.props;

const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#171918" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta property="og:site_name" content="TSBLV" />

    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Перейти к содержимому</a>
    <slot />
    <MotionProvider />
  </body>
</html>
