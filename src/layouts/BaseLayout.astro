---
import '../styles/global.css';
import MotionProvider from '../components/MotionProvider.astro';
import { siteConfig } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  noindex = false,
} = Astro.props;

const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
---

<!doctype html>
<html lang="ru" data-theme="light">
  <head>
    <script is:inline>
      try {
        const savedTheme = localStorage.getItem('tsblv-theme');
        if (savedTheme === 'dark') document.documentElement.dataset.theme = 'dark';
      } catch {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f2f1ed" data-theme-color />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}

    <title>{title}</title>
  </head>
  <body>
    <div class="theme-veil" data-theme-veil aria-hidden="true"></div>
    <a class="skip-link" href="#main-content">Перейти к содержимому</a>
    <slot />
    <MotionProvider />
  </body>
</html>
